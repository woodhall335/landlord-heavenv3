# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# official court forms required by server-side PDF generation
public/official-forms/**/*.pdf
!public/official-forms/*.pdf
!public/official-forms/Form_3A.pdf
!public/official-forms/Form_4A.pdf
!public/official-forms/N1_1224.pdf
!public/official-forms/N215.pdf
!public/official-forms/n5-eng.pdf
!public/official-forms/n5b-eng.pdf
!public/official-forms/n119-eng.pdf
!public/official-forms/n325-eng.pdf
!public/official-forms/N325A.pdf
!public/official-forms/N5_WALES_1222.pdf
!public/official-forms/N5B_WALES_0323.pdf
!public/official-forms/N119_WALES_1222.pdf
!public/official-forms/**/forms-manifest.json
!public/official-forms/README.md
!public/official-forms/scotland/notice_to_leave.pdf
!public/official-forms/scotland/form_e_eviction.pdf
!public/official-forms/scotland/form-3a.pdf
!public/official-forms/scotland/simple_procedure_response_form.pdf

# Sample/test documents (not to be committed)
sample-*.pdf
test-*.pdf
sample-*.html
test-*.html
artifacts/notice_only/_reports/

# Generated test output (PDFs, HTML, and debug artifacts)
tests/output/

.tmp/

# Audit and browser test artifacts
audit-output/**
!audit-output/.gitkeep
playwright-report/**
test-results/**
.lighthouseci/**
