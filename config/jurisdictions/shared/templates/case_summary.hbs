---
title: Eviction Case Summary
category: guidance
description: Overview of case facts and key details
filename: case_summary.pdf
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Eviction Case Summary</title>
  <style>
    {{{print_css}}}

    @page {
      size: A4;
      margin: 16mm;
    }

    body {
      font-family: Arial, sans-serif;
      font-size: 10pt;
      line-height: 1.55;
      color: #1a1a1a;
      margin: 0;
    }

    .header {
      margin-bottom: 1.5em;
      padding-bottom: 0.9em;
      border-bottom: 2px solid #1a1a1a;
    }

    .header h1 {
      margin: 0 0 0.3em 0;
      font-size: 17pt;
    }

    .header p {
      margin: 0.2em 0;
      color: #555;
    }

    .summary-box,
    .section,
    .callout {
      page-break-inside: avoid;
      break-inside: avoid;
    }

    .summary-box,
    .section {
      margin: 1.2em 0;
      border: 1px solid #d8d8d8;
      background: #fff;
    }

    .summary-box {
      padding: 1em;
      background: #fafafa;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: 190px 1fr;
      gap: 0.45em 1em;
    }

    .summary-grid dt {
      font-weight: 600;
      color: #444;
    }

    .summary-grid dd {
      margin: 0;
    }

    .section h2 {
      margin: 0;
      padding: 0.75em 0.95em;
      background: #1a1a1a;
      color: #fff;
      font-size: 11pt;
    }

    .section .content {
      padding: 1em;
    }

    p {
      margin: 0 0 0.75em 0;
    }

    ul {
      margin: 0.4em 0 0 1.2em;
    }

    li {
      margin: 0.4em 0;
    }

    .callout {
      margin: 1.2em 0;
      padding: 0.95em 1em;
      border-left: 4px solid #1a1a1a;
      background: #f7f7f7;
    }

    .money {
      font-weight: 700;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Eviction Case Summary</h1>
    <p>Prepared on {{current_date}}</p>
    {{#if notice_name}}<p>Notice relied on: {{notice_name}}</p>{{/if}}
  </div>

  <div class="summary-box">
    <dl class="summary-grid">
      {{#if (hasValue landlord_full_name)}}
      <dt>Landlord</dt>
      <dd>{{landlord_full_name}}{{#unless landlord_full_name}}{{landlord_name}}{{/unless}}</dd>
      {{/if}}
      {{#if (hasValue tenant_full_name)}}
      <dt>Tenant</dt>
      <dd>{{tenant_full_name}}{{#unless tenant_full_name}}{{tenant_name}}{{/unless}}{{#if tenant_2_name}}, {{tenant_2_name}}{{/if}}</dd>
      {{/if}}
      <dt>Property</dt>
      <dd>{{property_address}}</dd>
      {{#if court_name}}
      <dt>Court</dt>
      <dd>{{court_name}}</dd>
      {{/if}}
      {{#if ground_descriptions}}
      <dt>Grounds relied on</dt>
      <dd>{{ground_descriptions}}</dd>
      {{/if}}
      {{#if (hasValue tenancy_start_date_formatted)}}
      <dt>Tenancy start date</dt>
      <dd>{{tenancy_start_date_formatted}}</dd>
      {{/if}}
      {{#if (hasValue service_date_formatted)}}
      <dt>Notice service date</dt>
      <dd>{{service_date_formatted}}</dd>
      {{/if}}
      {{#if (hasValue notice_expiry_date_formatted)}}
      <dt>Notice expiry date</dt>
      <dd>{{notice_expiry_date_formatted}}</dd>
      {{/if}}
      {{#if (hasValue earliest_proceedings_date_formatted)}}
      <dt>Earliest proceedings date</dt>
      <dd>{{earliest_proceedings_date_formatted}}</dd>
      {{/if}}
      {{#if (hasValue latest_proceedings_date_formatted)}}
      <dt>Latest proceedings date</dt>
      <dd>{{latest_proceedings_date_formatted}}</dd>
      {{/if}}
      {{#if rent_amount}}
      <dt>Contract rent</dt>
      <dd>£{{rent_amount}} {{rent_frequency}}</dd>
      {{/if}}
      {{#if total_arrears}}
      <dt>Recorded arrears</dt>
      <dd class="money">£{{total_arrears}}</dd>
      {{/if}}
    </dl>
  </div>

  <div class="callout">
    <p>This summary draws together the key possession facts, the notice chronology, and the main points to be carried consistently across the support documents and any later court pack.</p>
  </div>

  <div class="section">
    <h2>Case Narrative</h2>
    <div class="content">
      {{#if drafting_model.caseSummary.narrativeParagraphs.length}}
        {{#each drafting_model.caseSummary.narrativeParagraphs}}
      <p>{{this}}</p>
        {{/each}}
      {{else}}
      <p>The landlord seeks possession of the property identified above using the route selected in the current case data.</p>
      {{#if case_summary}}<p>{{case_summary}}</p>{{/if}}
      {{/if}}
    </div>
  </div>

  {{#if (or drafting_model.caseSummary.stepsParagraphs.length drafting_model.previewSummary.readinessItems.length)}}
  <div class="section">
    <h2>Procedural Focus</h2>
    <div class="content">
      <ul>
        {{#if drafting_model.caseSummary.stepsParagraphs.length}}
          {{#each drafting_model.caseSummary.stepsParagraphs}}
        <li>{{this}}</li>
          {{/each}}
        {{else}}
          {{#each drafting_model.previewSummary.readinessItems}}
        <li>{{this}}</li>
          {{/each}}
        {{/if}}
      </ul>
    </div>
  </div>
  {{/if}}

  {{#if drafting_model.caseSummary.defendantCircumstancesParagraphs.length}}
  <div class="section">
    <h2>Defendant Circumstances</h2>
    <div class="content">
      {{#each drafting_model.caseSummary.defendantCircumstancesParagraphs}}
      <p>{{this}}</p>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{#if drafting_model.caseSummary.financialParagraphs.length}}
  <div class="section">
    <h2>Financial Position</h2>
    <div class="content">
      {{#each drafting_model.caseSummary.financialParagraphs}}
      <p>{{this}}</p>
      {{/each}}
    </div>
  </div>
  {{/if}}
</body>
</html>
