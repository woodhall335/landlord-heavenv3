{{!--
  ============================================================================
  EVIDENCE COLLECTION CHECKLIST
  ============================================================================
  Premium evidence checklist with England Section 8 ground-aware support and a
  generic fallback for other routes.
--}}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Evidence Collection Checklist</title>
  <style>
    {{{print_css}}}

    @page {
      size: A4;
      margin: 15mm;
    }

    body {
      font-family: Arial, sans-serif;
      font-size: 10pt;
      line-height: 1.55;
      color: #1a1a1a;
      margin: 0;
    }

    .header {
      margin-bottom: 1.5em;
      padding-bottom: 0.9em;
      border-bottom: 2px solid #1a1a1a;
      text-align: center;
    }

    .header h1 {
      margin: 0 0 0.3em 0;
      font-size: 16pt;
    }

    .header p {
      margin: 0.2em 0;
      color: #555;
    }

    .summary-box,
    .section,
    .callout {
      page-break-inside: avoid;
      break-inside: avoid;
    }

    .summary-box,
    .section {
      margin: 1.2em 0;
      border: 1px solid #d8d8d8;
      background: #fff;
    }

    .summary-box {
      padding: 1em;
      background: #fafafa;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 0.45em 1em;
    }

    .summary-grid dt {
      font-weight: 600;
      color: #444;
    }

    .summary-grid dd {
      margin: 0;
    }

    .section h2 {
      margin: 0;
      padding: 0.75em 0.95em;
      background: #1a1a1a;
      color: #fff;
      font-size: 11pt;
    }

    .section .content {
      padding: 1em;
    }

    .ground-block {
      margin: 1em 0 0 0;
      padding-top: 1em;
      border-top: 1px solid #e5e5e5;
    }

    .ground-block:first-child {
      margin-top: 0;
      padding-top: 0;
      border-top: none;
    }

    .ground-block h3 {
      margin: 0 0 0.45em 0;
      font-size: 10pt;
    }

    .note {
      margin: 0 0 0.7em 0;
      color: #666;
      font-size: 9pt;
    }

    .callout {
      margin: 1.2em 0;
      padding: 0.95em 1em;
      border-left: 4px solid #b45309;
      background: #fff7ed;
    }

    ul {
      margin: 0.35em 0 0 1.2em;
    }

    li {
      margin: 0.38em 0;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Evidence Collection Checklist</h1>
    <p>Use this checklist to assemble a clean, court-ready possession file.</p>
  </div>

  <div class="summary-box">
    <dl class="summary-grid">
      <dt>Property</dt>
      <dd>{{property_address}}</dd>
      {{#if (hasValue tenant_full_name)}}
      <dt>Tenant</dt>
      <dd>{{tenant_full_name}}{{#unless tenant_full_name}}{{tenant_name}}{{/unless}}</dd>
      {{/if}}
      <dt>Case type</dt>
      <dd>{{case_type}}</dd>
      {{#if ground_descriptions}}
      <dt>Grounds relied on</dt>
      <dd>{{ground_descriptions}}</dd>
      {{/if}}
      {{#if (hasValue service_date_formatted)}}
      <dt>Notice service date</dt>
      <dd>{{service_date_formatted}}</dd>
      {{/if}}
      {{#if (hasValue notice_expiry_date_formatted)}}
      <dt>Notice expiry date</dt>
      <dd>{{notice_expiry_date_formatted}}</dd>
      {{/if}}
      {{#if (hasValue earliest_proceedings_date_formatted)}}
      <dt>Earliest proceedings date</dt>
      <dd>{{earliest_proceedings_date_formatted}}</dd>
      {{/if}}
      {{#if (hasValue latest_proceedings_date_formatted)}}
      <dt>Latest proceedings date</dt>
      <dd>{{latest_proceedings_date_formatted}}</dd>
      {{/if}}
      <dt>Prepared</dt>
      <dd>{{current_date}}</dd>
    </dl>
  </div>

  {{#if is_england_post_2026}}
  <div class="callout">
    <p><strong>England post-1 May 2026 focus:</strong> keep the notice, service record, and ground-specific evidence aligned. The court should be able to follow the pack without guessing missing dates, missing documents, or why a specialist ground is said to apply.</p>
    {{#if has_ground_1a}}
    <p><strong>Ground 1A:</strong> keep sale evidence and any reletting-restriction awareness material with the main bundle.</p>
    {{/if}}
  </div>
  {{/if}}

  <div class="section">
    <h2>Core Documents</h2>
    <div class="content">
      {{#if drafting_model.evidenceChecklist.overviewParagraphs.length}}
        {{#each drafting_model.evidenceChecklist.overviewParagraphs}}
      <p>{{this}}</p>
        {{/each}}
      {{/if}}

      <ul>
        {{#if drafting_model.evidenceChecklist.collectionItems.length}}
          {{#each drafting_model.evidenceChecklist.collectionItems}}
        <li>{{this}}</li>
          {{/each}}
        {{else}}
          {{#each required_evidence}}
        <li>{{ground}}: {{title}}</li>
          {{/each}}
        {{/if}}
      </ul>
    </div>
  </div>

  {{#if drafting_model.evidenceChecklist.groundSections.length}}
  <div class="section">
    <h2>Ground-Specific Evidence</h2>
    <div class="content">
      {{#each drafting_model.evidenceChecklist.groundSections}}
      <div class="ground-block">
        <h3>{{title}}</h3>
        {{#if note}}<p class="note">{{note}}</p>{{/if}}
        <ul>
          {{#each items}}
          <li>{{this}}</li>
          {{/each}}
        </ul>
      </div>
      {{/each}}
    </div>
  </div>
  {{else if required_evidence.length}}
  <div class="section">
    <h2>Ground-Specific Evidence</h2>
    <div class="content">
      {{#each required_evidence}}
      <div class="ground-block">
        <h3>{{ground}} - {{title}}</h3>
        <ul>
          {{#each evidence_items}}
          <li>{{this}}</li>
          {{/each}}
        </ul>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{#if drafting_model.evidenceChecklist.finalChecks.length}}
  <div class="section">
    <h2>Final Checks Before Issue</h2>
    <div class="content">
      <ul>
        {{#each drafting_model.evidenceChecklist.finalChecks}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
    </div>
  </div>
  {{/if}}
</body>
</html>
