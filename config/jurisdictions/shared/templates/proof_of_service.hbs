{{!--
  ============================================================================
  PROOF OF SERVICE CERTIFICATE
  ============================================================================
  Court-facing support record for notice service.
--}}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Proof of Service Certificate</title>
  <style>
    {{{print_css}}}

    @page {
      size: A4;
      margin: 20mm;
    }

    body {
      margin: 0;
      padding: 0;
      color: #1a1a1a;
      font-size: 11pt;
      line-height: 1.6;
    }

    .doc-header {
      text-align: center;
      margin-bottom: 1.75em;
      padding-bottom: 1em;
      border-bottom: 2px solid #1a1a1a;
    }

    .doc-header h1 {
      margin: 0 0 0.25em 0;
      font-size: 17pt;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .doc-subtitle {
      color: #555;
      font-size: 10pt;
    }

    .reference {
      margin: 1em 0 1.5em 0;
      text-align: right;
      font-size: 9pt;
      color: #666;
    }

    .details-box,
    .signature-section,
    .notice-box {
      page-break-inside: avoid;
      break-inside: avoid;
    }

    .notice-box,
    .details-box {
      margin: 1.5em 0;
      padding: 1.2em;
      border: 1px solid #d8d8d8;
      background: #fff;
    }

    .details-grid {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 0.55em 1em;
    }

    .details-grid dt {
      font-weight: 600;
      color: #444;
    }

    .details-grid dd {
      margin: 0;
    }

    .method-options {
      margin-top: 0.75em;
    }

    .method-row {
      display: flex;
      gap: 0.75em;
      margin: 0.55em 0;
    }

    .checkbox {
      width: 16px;
      height: 16px;
      border: 1px solid #1a1a1a;
      flex-shrink: 0;
      margin-top: 0.2em;
    }

    .checkbox.checked {
      background: #1a1a1a;
    }

    .signature-section {
      margin-top: 2em;
    }

    .signature-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5em;
    }

    .signature-box {
      border: 1px solid #d8d8d8;
      padding: 1em;
    }

    .signature-line {
      height: 2.5em;
      border-bottom: 1px solid #1a1a1a;
      margin-top: 1em;
    }

    .doc-footer {
      margin-top: 2em;
      padding-top: 1em;
      border-top: 1px solid #d8d8d8;
      font-size: 9pt;
      color: #555;
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="doc-header">
    <h1>Certificate of Service</h1>
    <div class="doc-subtitle">Proof of notice service for possession proceedings</div>
  </div>

  <div class="reference">
    Reference: POS-{{case_id}}-{{current_date_short}}
  </div>

  <div class="notice-box">
    <p>{{#if (hasValue landlord_full_name)}}I, <strong>{{landlord_full_name}}</strong>, certify{{else}}I certify{{/if}} that the notice described below was served in the manner indicated on the tenant at:</p>
    <p><strong>{{property_address}}</strong></p>
  </div>

  <div class="details-box">
    <h2>Notice details</h2>
    <dl class="details-grid">
      {{#if (hasValue notice_name)}}
      <dt>Notice type</dt>
      <dd>{{notice_name}}</dd>
      {{/if}}
      <dt>Tenant name(s)</dt>
      <dd>{{tenant_full_name}}{{#if tenant_2_name}}, {{tenant_2_name}}{{/if}}</dd>
      <dt>Service address</dt>
      <dd>{{property_address}}</dd>
      {{#if (hasValue service_date_formatted)}}
      <dt>Date of service</dt>
      <dd>{{service_date_formatted}}</dd>
      {{/if}}
      {{#if (hasValue notice_expiry_date_formatted)}}
      <dt>Notice expiry date</dt>
      <dd>{{notice_expiry_date_formatted}}</dd>
      {{/if}}
      {{#if (hasValue earliest_proceedings_date_formatted)}}
      <dt>Earliest proceedings date</dt>
      <dd>{{earliest_proceedings_date_formatted}}</dd>
      {{/if}}
      {{#if (hasValue latest_proceedings_date_formatted)}}
      <dt>Latest proceedings date</dt>
      <dd>{{latest_proceedings_date_formatted}}</dd>
      {{/if}}
    </dl>
  </div>

  <div class="details-box">
    <h2>Method of service</h2>
    <div class="method-options">
      <div class="method-row">
        <div class="checkbox {{#if (eq service_method 'hand')}}checked{{/if}}"></div>
        <div>Hand delivery through the letterbox or directly to the tenant</div>
      </div>
      <div class="method-row">
        <div class="checkbox {{#if (eq service_method 'post')}}checked{{/if}}"></div>
        <div>First class post</div>
      </div>
      <div class="method-row">
        <div class="checkbox {{#if (eq service_method 'recorded_delivery')}}checked{{/if}}"></div>
        <div>Recorded or signed delivery</div>
      </div>
      {{#unless (or (eq service_method 'hand') (eq service_method 'post') (eq service_method 'recorded_delivery'))}}
      <div class="method-row">
        <div class="checkbox {{#if (hasValue service_method)}}checked{{/if}}"></div>
        <div>Other method{{#if (hasValue service_method)}}: {{service_method}}{{else}} (specify if used){{/if}}</div>
      </div>
      {{/unless}}
    </div>
  </div>

  <div class="details-box">
    <h2>Supporting record</h2>
    {{#if drafting_model.proofOfService.recordParagraphs.length}}
      {{#each drafting_model.proofOfService.recordParagraphs}}
      <p>{{this}}</p>
      {{/each}}
    {{else}}
      <p>Keep any witness details, photographs, proof of posting, or tracking references with the served-copy file for this notice.</p>
      <p>If extra service evidence exists, attach it behind this certificate in the same bundle.</p>
    {{/if}}
  </div>

  <div class="signature-section">
    <h2>Declaration and signature</h2>
    <p>I believe the information in this certificate is true and accurate to the best of my knowledge. I understand that it may be relied on in court proceedings.</p>

    <div class="signature-grid">
      <div class="signature-box">
        <p><strong>Landlord / agent</strong></p>
        <div class="signature-line"></div>
        <p>Signature</p>
        <div class="signature-line"></div>
        <p>Print name</p>
        <div class="signature-line"></div>
        <p>Date</p>
      </div>
      {{#if (or (hasValue witness_name) (hasValue witness_full_name) (hasValue witness_address) (hasValue service_witness_required))}}
      <div class="signature-box">
        <p><strong>Witness (if applicable)</strong></p>
        <div class="signature-line"></div>
        <p>Signature</p>
        <div class="signature-line"></div>
        <p>Print name</p>
        <div class="signature-line"></div>
        <p>Address</p>
      </div>
      {{/if}}
    </div>
  </div>

  <div class="doc-footer">
    <p><strong>Generated:</strong> {{current_date}}</p>
    {{#unless clean_output}}
    <p><strong>Landlord Heaven</strong> | Proof of service support document</p>
    {{/unless}}
  </div>
</body>
</html>
