{{!--
  ============================================================================
  COMPLIANCE CHECKLIST - PRE-SERVICE DECISION ENGINE
  ============================================================================
  Structured England Section 8 compliance summary built from shared risk items.
--}}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Compliance Checklist - Pre-Service Checks</title>
  <style>
    {{{print_css}}}

    @page {
      size: A4;
      margin: 10mm;
    }

    body {
      margin: 0;
      color: #1f1635;
      font-size: 10pt;
      line-height: 1.55;
    }

    .hero,
    .summary-box,
    .legend-item,
    .item,
    .action-box {
      page-break-inside: avoid;
      break-inside: avoid;
    }

    .hero {
      border: 1px solid #ddd6fe;
      background: #faf8ff;
      padding: 1.2em;
      margin-bottom: 1em;
    }

    .hero h1 {
      margin: 0 0 0.2em 0;
      font-size: 18pt;
    }

    .hero h2 {
      margin: 0 0 0.35em 0;
      font-size: 11pt;
      color: #5b5370;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .hero p {
      margin: 0.25em 0;
    }

    .summary-box,
    .legend-item,
    .item,
    .action-box {
      border: 1px solid #e5e7eb;
      background: #fff;
    }

    .summary-box,
    .action-box {
      padding: 1em;
      margin-bottom: 0.9em;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: 170px 1fr;
      gap: 0.45em 0.9em;
    }

    .summary-grid dt {
      font-weight: 700;
      color: #5b5370;
    }

    .summary-grid dd {
      margin: 0;
    }

    .legend {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.8em;
      margin-bottom: 1em;
    }

    .legend-item {
      padding: 0.9em;
    }

    .status-chip {
      display: inline-block;
      margin-bottom: 0.45em;
      padding: 0.18em 0.55em;
      border-radius: 999px;
      font-size: 8.5pt;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      background: #ede9fe;
      color: #4c1d95;
    }

    .status-chip.ok {
      background: #dcfce7;
      color: #166534;
    }

    .status-chip.risk {
      background: #ffedd5;
      color: #9a3412;
    }

    .status-chip.critical {
      background: #fee2e2;
      color: #991b1b;
    }

    .section-title {
      margin: 1.2em 0 0.65em 0;
      font-size: 12pt;
      font-weight: 700;
      color: #231942;
    }

    .items {
      display: grid;
      gap: 0.9em;
    }

    .item {
      padding: 1em;
    }

    .item.ok {
      border-color: #bbf7d0;
      background: #f0fdf4;
    }

    .item.risk {
      border-color: #fed7aa;
      background: #fff7ed;
    }

    .item.critical {
      border-color: #fecaca;
      background: #fef2f2;
    }

    .item h3,
    .action-box h3 {
      margin: 0 0 0.4em 0;
      font-size: 10.5pt;
      color: #231942;
    }

    .item p,
    .action-box p {
      margin: 0.3em 0;
    }

    .muted {
      color: #6b7280;
    }
  </style>
</head>
<body>
  <div class="hero">
    <h2>{{pack_title}}</h2>
    <h1>Compliance Checklist</h1>
    <p><strong>{{status_label}}</strong></p>
    <p>{{pack_supporting_line}}</p>
    <p class="muted">{{risk_line}}</p>
  </div>

  <div class="summary-box">
    <dl class="summary-grid">
      <dt>Property</dt>
      <dd>{{property_address}}</dd>
      <dt>Tenant</dt>
      <dd>{{tenant_full_name}}{{#if tenant_2_name}}, {{tenant_2_name}}{{/if}}</dd>
      <dt>Notice type</dt>
      <dd>{{notice_name}}</dd>
      {{#if tenancy_start_date}}
      <dt>Tenancy start date</dt>
      <dd>{{format_date tenancy_start_date "long"}}</dd>
      {{/if}}
      <dt>Generated</dt>
      <dd>{{format_date current_date "long"}}</dd>
    </dl>
  </div>

  <div class="legend">
    <div class="legend-item">
      <div class="status-chip critical">Critical</div>
      <p>Resolve this before relying on the notice or moving on with the case.</p>
    </div>
    <div class="legend-item">
      <div class="status-chip risk">Risk</div>
      <p>This may not automatically invalidate the route, but it can weaken the file or create delay.</p>
    </div>
    <div class="legend-item">
      <div class="status-chip ok">OK</div>
      <p>The current pack data records this point, but you still need to retain the underlying evidence.</p>
    </div>
  </div>

  <h2 class="section-title">Decision Engine</h2>
  <div class="items">
    {{#each compliance_status_items}}
    <div class="item {{severity}}">
      <div class="status-chip {{severity}}">{{severity}}</div>
      <h3>{{title}}</h3>
      <p>{{detail}}</p>
      <p><strong>Action:</strong> {{action}}</p>
    </div>
    {{/each}}
  </div>

  <h2 class="section-title">Next move</h2>
  <div class="action-box">
    <h3>{{status_label}}</h3>
    <p>{{next_step_text}}</p>
    <p class="muted">Use this checklist as a practical decision engine. It does not replace the tenancy file, the service record, or legal advice on the facts of the case.</p>
  </div>
</body>
</html>
