{{!--
  ============================================================================
  COURT BUNDLE INDEX
  ============================================================================
  Court-facing bundle index for England Section 8 possession proceedings.
--}}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Court Bundle Index</title>
  <style>
    {{{print_css}}}

    @page {
      size: A4;
      margin: 15mm;
    }

    body {
      margin: 0 auto;
      padding: 0;
      color: #1a1a1a;
      font-size: 10pt;
      line-height: 1.5;
    }

    .bundle-header {
      text-align: center;
      margin-bottom: 1.5em;
      padding-bottom: 1em;
      border-bottom: 2px solid #1a1a1a;
    }

    .bundle-header h1 {
      margin: 0 0 0.35em 0;
      font-size: 16pt;
    }

    .bundle-header h2 {
      margin: 0;
      font-size: 11pt;
      color: #555;
      font-weight: 400;
    }

    .case-details,
    .notes-section,
    .index-table {
      page-break-inside: avoid;
      break-inside: avoid;
    }

    .case-details,
    .notes-section {
      margin-bottom: 1.5em;
      padding: 1em;
      border: 1px solid #d8d8d8;
      background: #fafafa;
    }

    .case-details-grid {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 0.45em 1em;
    }

    .case-details-grid dt {
      font-weight: 600;
    }

    .case-details-grid dd {
      margin: 0;
    }

    .index-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 1.5em;
    }

    .index-table th,
    .index-table td {
      padding: 8px 10px;
      border: 1px solid #1a1a1a;
      text-align: left;
      vertical-align: top;
    }

    .index-table th {
      background: #1a1a1a;
      color: white;
      font-weight: 700;
    }

    .section-header td {
      background: #efefef;
      font-weight: 700;
    }

    .tab-number,
    .page-ref,
    .checkbox-col {
      text-align: center;
      white-space: nowrap;
    }

    .checkbox {
      display: inline-block;
      width: 14px;
      height: 14px;
      border: 1px solid #1a1a1a;
      background: white;
    }

    .footer {
      margin-top: 2em;
      padding-top: 1em;
      border-top: 1px solid #d8d8d8;
      font-size: 9pt;
      color: #555;
    }
  </style>
</head>
<body>
  <div class="bundle-header">
    <h1>Court Bundle Index</h1>
    <h2>Claim for possession of residential property</h2>
  </div>

  <div class="case-details">
    <dl class="case-details-grid">
      <dt>Case number</dt>
      <dd><em>To be assigned by court</em></dd>
      {{#if (hasValue court_name)}}
      <dt>Court</dt>
      <dd>{{court_name}}</dd>
      {{/if}}
      <dt>Claimant</dt>
      <dd>{{landlord_full_name}}</dd>
      <dt>Defendant</dt>
      <dd>{{tenant_full_name}}{{#if tenant_2_name}}, {{tenant_2_name}}{{/if}}</dd>
      <dt>Property</dt>
      <dd>{{property_address}}</dd>
      {{#if (hasValue notice_service_date)}}
      <dt>Notice service date</dt>
      <dd>{{format_date notice_service_date "long"}}</dd>
      {{/if}}
      {{#if (hasValue notice_expiry_date)}}
      <dt>Notice expiry date</dt>
      <dd>{{format_date notice_expiry_date "long"}}</dd>
      {{/if}}
      {{#if (hasValue earliest_proceedings_date)}}
      <dt>Earliest proceedings date</dt>
      <dd>{{format_date earliest_proceedings_date "long"}}</dd>
      {{/if}}
      <dt>Bundle prepared</dt>
      <dd>{{format_date generated_date "long"}}</dd>
    </dl>
  </div>

  <table class="index-table">
    <thead>
      <tr>
        <th class="checkbox-col">Done</th>
        <th class="tab-number">Tab</th>
        <th>Document</th>
        <th>Description</th>
        <th class="page-ref">Exhibit</th>
        <th class="page-ref">Pages</th>
      </tr>
    </thead>
    <tbody>
      <tr class="section-header">
        <td colspan="6">A. Court forms</td>
      </tr>
      <tr>
        <td class="checkbox-col"><span class="checkbox"></span></td>
        <td class="tab-number">A1</td>
        <td>Form N5</td>
        <td>Claim for possession of property</td>
        <td class="page-ref"></td>
        <td class="page-ref"></td>
      </tr>
      <tr>
        <td class="checkbox-col"><span class="checkbox"></span></td>
        <td class="tab-number">A2</td>
        <td>Form N119</td>
        <td>Particulars of claim for possession</td>
        <td class="page-ref"></td>
        <td class="page-ref"></td>
      </tr>

      <tr class="section-header">
        <td colspan="6">B. Notice documents</td>
      </tr>
      <tr>
        <td class="checkbox-col"><span class="checkbox"></span></td>
        <td class="tab-number">B1</td>
        <td>{{notice_name}}</td>
        <td>{{notice_title}}</td>
        <td class="page-ref">{{bundle_exhibit_section8_notice}}</td>
        <td class="page-ref"></td>
      </tr>
      <tr>
        <td class="checkbox-col"><span class="checkbox"></span></td>
        <td class="tab-number">B2</td>
        <td>Proof of service certificate</td>
        <td>Service record for the {{notice_name}}</td>
        <td class="page-ref">{{bundle_exhibit_proof_of_service}}</td>
        <td class="page-ref"></td>
      </tr>

      <tr class="section-header">
        <td colspan="6">C. Witness evidence</td>
      </tr>
      <tr>
        <td class="checkbox-col"><span class="checkbox"></span></td>
        <td class="tab-number">C1</td>
        <td>Witness statement</td>
        <td>Witness statement of {{landlord_full_name}}</td>
        <td class="page-ref"></td>
        <td class="page-ref"></td>
      </tr>

      <tr class="section-header">
        <td colspan="6">D. Arrears evidence</td>
      </tr>
      <tr>
        <td class="checkbox-col"><span class="checkbox"></span></td>
        <td class="tab-number">D1</td>
        <td>Schedule of arrears</td>
        <td>Period-by-period breakdown of rent due and payments</td>
        <td class="page-ref">{{bundle_exhibit_schedule_of_arrears}}</td>
        <td class="page-ref"></td>
      </tr>
      <tr>
        <td class="checkbox-col"><span class="checkbox"></span></td>
        <td class="tab-number">D2</td>
        <td>Bank statements</td>
        <td>Payment history evidence, if available</td>
        <td class="page-ref"></td>
        <td class="page-ref"></td>
      </tr>

      <tr class="section-header">
        <td colspan="6">E. Tenancy documents</td>
      </tr>
      <tr>
        <td class="checkbox-col"><span class="checkbox"></span></td>
        <td class="tab-number">E1</td>
        <td>Tenancy agreement</td>
        <td>Signed tenancy agreement</td>
        <td class="page-ref"></td>
        <td class="page-ref"></td>
      </tr>
      <tr>
        <td class="checkbox-col"><span class="checkbox"></span></td>
        <td class="tab-number">E2</td>
        <td>Deposit evidence</td>
        <td>Deposit protection or prescribed information records, if relevant</td>
        <td class="page-ref"></td>
        <td class="page-ref"></td>
      </tr>

      {{#if bundle_verified_exhibits.length}}
      <tr class="section-header">
        <td colspan="6">F. Verified supporting documents</td>
      </tr>
      {{#each bundle_verified_exhibits}}
      <tr>
        <td class="checkbox-col"><span class="checkbox"></span></td>
        <td class="tab-number">{{tab}}</td>
        <td>{{title}}</td>
        <td>{{description}}</td>
        <td class="page-ref">{{label}}</td>
        <td class="page-ref"></td>
      </tr>
      {{/each}}
      {{/if}}

      <tr class="section-header">
        <td colspan="6">G. Correspondence</td>
      </tr>
      <tr>
        <td class="checkbox-col"><span class="checkbox"></span></td>
        <td class="tab-number">G1</td>
        <td>Pre-action correspondence</td>
        <td>Letters, emails, or messages sent before issue</td>
        <td class="page-ref"></td>
        <td class="page-ref"></td>
      </tr>
      <tr>
        <td class="checkbox-col"><span class="checkbox"></span></td>
        <td class="tab-number">G2</td>
        <td>Tenant responses</td>
        <td>Any response received from the tenant</td>
        <td class="page-ref"></td>
        <td class="page-ref"></td>
      </tr>
    </tbody>
  </table>

  <div class="notes-section">
    <h3>Bundle preparation notes</h3>
    <ul>
      <li>Number all pages consecutively throughout the bundle.</li>
      <li>Update this index if you add or remove documents.</li>
      <li>Bring originals of the main documents to the hearing.</li>
      <li>Check any local court directions before filing the bundle.</li>
    </ul>
  </div>

  <div class="footer">
    <p><strong>Prepared by:</strong> {{landlord_full_name}}</p>
    <p><strong>Date:</strong> {{format_date generated_date "long"}}</p>
    {{#unless clean_output}}
    <p><strong>Landlord Heaven</strong> | Court bundle support document</p>
    {{/unless}}
  </div>
</body>
</html>
