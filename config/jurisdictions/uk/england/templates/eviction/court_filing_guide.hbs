---
title: Court Filing Guide
category: guidance
description: How to file your England post-2026 possession claim
filename: court_filing_guide.pdf
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Court Filing Guide - England</title>
  <style>
    {{{print_css}}}

    @page {
      size: A4;
      margin: 16mm;
    }

    body {
      font-family: Arial, sans-serif;
      font-size: 10pt;
      line-height: 1.55;
      color: #1a1a1a;
      margin: 0;
    }

    .header {
      margin-bottom: 1.5em;
      padding-bottom: 0.9em;
      border-bottom: 2px solid #1a1a1a;
      text-align: center;
    }

    .header h1 {
      margin: 0 0 0.3em 0;
      font-size: 17pt;
    }

    .header p {
      margin: 0.2em 0;
      color: #555;
    }

    .summary-box,
    .section,
    .callout {
      page-break-inside: avoid;
      break-inside: avoid;
    }

    .summary-box,
    .section {
      margin: 1.2em 0;
      border: 1px solid #d8d8d8;
      background: #fff;
    }

    .summary-box {
      padding: 1em;
      background: #fafafa;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: 190px 1fr;
      gap: 0.45em 1em;
    }

    .summary-grid dt {
      font-weight: 600;
      color: #444;
    }

    .summary-grid dd {
      margin: 0;
    }

    .section h2 {
      margin: 0;
      padding: 0.75em 0.95em;
      background: #1a1a1a;
      color: #fff;
      font-size: 11pt;
    }

    .section .content {
      padding: 1em;
    }

    .callout {
      margin: 1.2em 0;
      padding: 0.95em 1em;
      border-left: 4px solid #b45309;
      background: #fff7ed;
    }

    p {
      margin: 0 0 0.75em 0;
    }

    ul {
      margin: 0.35em 0 0 1.2em;
    }

    li {
      margin: 0.38em 0;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Court Filing Guide</h1>
    <p>England possession claim guidance for the current pack.</p>
  </div>

  <div class="summary-box">
    <dl class="summary-grid">
      {{#if court_name}}
      <dt>Court</dt>
      <dd>{{court_name}}</dd>
      {{/if}}
      {{#if (hasValue landlord_full_name)}}
      <dt>Landlord</dt>
      <dd>{{landlord_full_name}}{{#unless landlord_full_name}}{{landlord_name}}{{/unless}}</dd>
      {{/if}}
      {{#if (hasValue tenant_full_name)}}
      <dt>Tenant</dt>
      <dd>{{tenant_full_name}}{{#unless tenant_full_name}}{{tenant_name}}{{/unless}}{{#if tenant_2_name}}, {{tenant_2_name}}{{/if}}</dd>
      {{/if}}
      <dt>Property</dt>
      <dd>{{property_address}}</dd>
      {{#if ground_descriptions}}
      <dt>Grounds relied on</dt>
      <dd>{{ground_descriptions}}</dd>
      {{/if}}
      {{#if (hasValue service_date_formatted)}}
      <dt>Notice service date</dt>
      <dd>{{service_date_formatted}}</dd>
      {{/if}}
      {{#if (hasValue earliest_proceedings_date_formatted)}}
      <dt>Earliest proceedings date</dt>
      <dd>{{earliest_proceedings_date_formatted}}</dd>
      {{/if}}
      {{#if (hasValue latest_proceedings_date_formatted)}}
      <dt>Latest proceedings date</dt>
      <dd>{{latest_proceedings_date_formatted}}</dd>
      {{/if}}
    </dl>
  </div>

  <div class="callout">
    {{#if drafting_model.courtFilingGuide.overviewParagraphs.length}}
      {{#each drafting_model.courtFilingGuide.overviewParagraphs}}
    <p>{{this}}</p>
      {{/each}}
    {{else}}
    <p>Before filing the claim, make sure the court forms, the notice, and the support documents all use the same facts, dates, and parties.</p>
    {{/if}}
  </div>

  <div class="section">
    <h2>Before Issue</h2>
    <div class="content">
      <ul>
        {{#if drafting_model.courtFilingGuide.preparationItems.length}}
          {{#each drafting_model.courtFilingGuide.preparationItems}}
        <li>{{this}}</li>
          {{/each}}
        {{else}}
        <li>Check that the notice period has expired and the dates in the pack still match.</li>
        <li>Review the claim forms and supporting documents together before filing.</li>
        {{/if}}
      </ul>
    </div>
  </div>

  <div class="section">
    <h2>What To File</h2>
    <div class="content">
      <ul>
        {{#if drafting_model.courtFilingGuide.filingItems.length}}
          {{#each drafting_model.courtFilingGuide.filingItems}}
        <li>{{this}}</li>
          {{/each}}
        {{else}}
        <li>Form N5 claim form and Form N119 particulars of claim.</li>
        <li>The served notice and proof of service.</li>
        <li>The tenancy agreement and supporting evidence for the pleaded grounds.</li>
        {{/if}}
      </ul>
    </div>
  </div>

  {{#if drafting_model.courtFilingGuide.afterIssueItems.length}}
  <div class="section">
    <h2>After Issue</h2>
    <div class="content">
      <ul>
        {{#each drafting_model.courtFilingGuide.afterIssueItems}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
    </div>
  </div>
  {{/if}}

  {{#if drafting_model.courtFilingGuide.warningParagraphs.length}}
  <div class="callout">
    {{#each drafting_model.courtFilingGuide.warningParagraphs}}
    <p>{{this}}</p>
    {{/each}}
  </div>
  {{/if}}
</body>
</html>
