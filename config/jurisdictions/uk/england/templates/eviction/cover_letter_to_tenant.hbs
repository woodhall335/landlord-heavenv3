---
title: Cover Letter to Tenant
category: guidance
description: Non-statutory cover letter to send with Form 3A
filename: cover_letter_to_tenant.pdf
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Cover Letter to Tenant</title>
  <style>
    {{{print_css}}}

    body {
      font-family: Arial, sans-serif;
      font-size: 10.5pt;
      line-height: 1.6;
      color: #1a1a1a;
      margin: 0 auto;
      max-width: 760px;
      padding: 0;
    }

    .letterhead {
      margin-bottom: 2em;
      padding-bottom: 1em;
      border-bottom: 2px solid #1a1a1a;
    }

    .sender,
    .recipient {
      white-space: pre-line;
    }

    .meta {
      margin: 1em 0 1.5em 0;
    }

    .subject {
      margin: 1.25em 0 0.85em 0;
      font-weight: 700;
      text-transform: uppercase;
    }

    .notice-box,
    .callout {
      margin: 1em 0 1.5em 0;
      padding: 1em;
      border: 1px solid #d8d8d8;
      background: #fafafa;
    }

    .notice-box p,
    .callout p {
      margin: 0.35em 0;
    }

    ul {
      margin: 0.5em 0 0 1.2em;
    }

    li {
      margin: 0.35em 0;
    }

    .closing {
      margin-top: 1.75em;
    }

    .small-note {
      margin-top: 1.5em;
      padding-top: 0.8em;
      border-top: 1px solid #d8d8d8;
      font-size: 9pt;
      color: #555;
    }
  </style>
</head>
<body>
  <div class="letterhead">
    {{#if (hasValue landlord_full_name)}}
    <div class="sender">{{landlord_full_name}}</div>
    {{/if}}
    {{#if landlord_address}}<div class="sender">{{landlord_address}}</div>{{/if}}
  </div>

  <div class="recipient">
    {{#if (hasValue tenant_full_name)}}{{tenant_full_name}}{{else}}Tenant{{/if}}
    {{#if property_address}}
    {{property_address}}
    {{/if}}
  </div>

  <div class="meta">
    <p><strong>Date:</strong> {{current_date}}</p>
    {{#if property_address}}<p><strong>Property:</strong> {{property_address}}</p>{{/if}}
  </div>

  <div class="subject">Enclosed: {{notice_name}}</div>

  <p>Dear {{#if (hasValue tenant_full_name)}}{{tenant_full_name}}{{else}}Tenant{{/if}},</p>

  {{#if drafting_model.coverLetter.introParagraphs.length}}
    {{#each drafting_model.coverLetter.introParagraphs}}
  <p>{{this}}</p>
    {{/each}}
  {{else}}
  <p>Please find enclosed the {{notice_name}} relating to the above property.</p>
  {{/if}}

  <div class="notice-box">
    <p><strong>This letter is not the notice itself.</strong> The legal notice is the enclosed {{notice_name}}.</p>
    {{#if (hasValue service_date_formatted)}}<p><strong>Notice service date:</strong> {{service_date_formatted}}</p>{{/if}}
    {{#if (hasValue notice_expiry_date_formatted)}}<p><strong>Notice expiry date:</strong> {{notice_expiry_date_formatted}}</p>{{/if}}
    {{#if (hasValue earliest_proceedings_date_formatted)}}<p><strong>Earliest proceedings date:</strong> {{earliest_proceedings_date_formatted}}</p>{{/if}}
    {{#if (hasValue latest_proceedings_date_formatted)}}<p><strong>Latest proceedings date:</strong> {{latest_proceedings_date_formatted}}</p>{{/if}}
    {{#if ground_descriptions}}<p><strong>Grounds relied on:</strong> {{ground_descriptions}}</p>{{/if}}
  </div>

  {{#if drafting_model.coverLetter.actionItems.length}}
  <div class="callout">
    <p><strong>Practical next steps:</strong></p>
    <ul>
      {{#each drafting_model.coverLetter.actionItems}}
      <li>{{this}}</li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  {{#if drafting_model.coverLetter.closingParagraphs.length}}
    {{#each drafting_model.coverLetter.closingParagraphs}}
  <p>{{this}}</p>
    {{/each}}
  {{/if}}

  <div class="closing">
    <p>Yours sincerely,</p>
    {{#if (hasValue landlord_full_name)}}
    <p>{{landlord_full_name}}</p>
    {{/if}}
  </div>

  <p class="small-note">This covering letter is a support document provided for clarity. It does not replace the enclosed {{notice_name}} and is not itself a statutory notice.</p>
</body>
</html>
