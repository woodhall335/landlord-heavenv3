{{!--
  ============================================================================
  EVICTION ROADMAP & TIMELINE
  ============================================================================
  Premium England roadmap with a calmer, court-facing structure.
--}}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Eviction Roadmap & Timeline</title>
  <style>
    {{{print_css}}}

    @page {
      size: A4;
      margin: 15mm;
    }

    body {
      font-family: Arial, sans-serif;
      font-size: 10pt;
      line-height: 1.55;
      color: #1a1a1a;
      margin: 0;
    }

    .header {
      margin-bottom: 1.5em;
      padding-bottom: 0.9em;
      border-bottom: 2px solid #1a1a1a;
      text-align: center;
    }

    .header h1 {
      margin: 0 0 0.3em 0;
      font-size: 16pt;
    }

    .header p {
      margin: 0.2em 0;
      color: #555;
    }

    .summary-box,
    .stage,
    .callout {
      page-break-inside: avoid;
      break-inside: avoid;
    }

    .summary-box,
    .stage {
      margin: 1.2em 0;
      border: 1px solid #d8d8d8;
      background: #fff;
    }

    .summary-box {
      padding: 1em;
      background: #fafafa;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 0.45em 1em;
    }

    .summary-grid dt {
      font-weight: 600;
      color: #444;
    }

    .summary-grid dd {
      margin: 0;
    }

    .stage h2 {
      margin: 0;
      padding: 0.75em 0.95em;
      background: #1a1a1a;
      color: #fff;
      font-size: 11pt;
    }

    .stage .content {
      padding: 1em;
    }

    .callout {
      margin: 1.2em 0;
      padding: 0.95em 1em;
      border-left: 4px solid #b45309;
      background: #fff7ed;
    }

    p {
      margin: 0 0 0.75em 0;
    }

    ul {
      margin: 0.35em 0 0 1.2em;
    }

    li {
      margin: 0.38em 0;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Eviction Roadmap &amp; Timeline</h1>
    <p>A practical sequence from service of notice to any later enforcement step.</p>
  </div>

  <div class="summary-box">
    <dl class="summary-grid">
      <dt>Property</dt>
      <dd>{{property_address}}</dd>
      {{#if (hasValue tenant_full_name)}}
      <dt>Tenant</dt>
      <dd>{{tenant_full_name}}{{#unless tenant_full_name}}{{tenant_name}}{{/unless}}</dd>
      {{/if}}
      <dt>Notice</dt>
      <dd>{{notice_name}}{{#unless notice_name}}{{notice_type}}{{/unless}}</dd>
      {{#if ground_descriptions}}
      <dt>Grounds relied on</dt>
      <dd>{{ground_descriptions}}</dd>
      {{/if}}
      {{#if (hasValue service_date_formatted)}}
      <dt>Notice service date</dt>
      <dd>{{service_date_formatted}}</dd>
      {{/if}}
      {{#if (hasValue earliest_proceedings_date_formatted)}}
      <dt>Earliest proceedings date</dt>
      <dd>{{earliest_proceedings_date_formatted}}</dd>
      {{/if}}
      {{#if (hasValue latest_proceedings_date_formatted)}}
      <dt>Latest proceedings date</dt>
      <dd>{{latest_proceedings_date_formatted}}</dd>
      {{/if}}
    </dl>
  </div>

  <div class="callout">
    {{#if drafting_model.roadmap.overviewParagraphs.length}}
      {{#each drafting_model.roadmap.overviewParagraphs}}
    <p>{{this}}</p>
      {{/each}}
    {{else}}
    <p>Serve the notice correctly, preserve the service evidence, and only move to the claim stage once the notice period has expired and the underlying facts are still current.</p>
    {{/if}}
  </div>

  <div class="stage">
    <h2>Stage 1: Serve The Notice</h2>
    <div class="content">
      <ul>
        {{#if drafting_model.roadmap.noticeStageItems.length}}
          {{#each drafting_model.roadmap.noticeStageItems}}
        <li>{{this}}</li>
          {{/each}}
        {{else}}
        <li>Serve the notice using a permitted method and record how service took place.</li>
        <li>Keep the served notice and proof of service together.</li>
        {{/if}}
      </ul>
    </div>
  </div>

  <div class="stage">
    <h2>Stage 2: Decide Whether To Issue</h2>
    <div class="content">
      <ul>
        {{#if drafting_model.roadmap.issueStageItems.length}}
          {{#each drafting_model.roadmap.issueStageItems}}
        <li>{{this}}</li>
          {{/each}}
        {{else}}
        <li>Once the notice period has expired, decide whether the matter has been resolved or whether court proceedings are required.</li>
        <li>Update the supporting evidence before drafting the claim.</li>
        {{/if}}
      </ul>
    </div>
  </div>

  <div class="stage">
    <h2>Stage 3: Prepare For Hearing</h2>
    <div class="content">
      <ul>
        {{#if drafting_model.roadmap.hearingStageItems.length}}
          {{#each drafting_model.roadmap.hearingStageItems}}
        <li>{{this}}</li>
          {{/each}}
        {{else}}
        <li>Bring the notice, proof of service, and supporting documents to the hearing.</li>
        <li>Keep submissions short and tied to the pleaded grounds.</li>
        {{/if}}
      </ul>
    </div>
  </div>

  <div class="stage">
    <h2>Stage 4: After The Order</h2>
    <div class="content">
      <ul>
        {{#if drafting_model.roadmap.enforcementStageItems.length}}
          {{#each drafting_model.roadmap.enforcementStageItems}}
        <li>{{this}}</li>
          {{/each}}
        {{else}}
        <li>If a possession order is made and not complied with, consider the appropriate enforcement step.</li>
        {{/if}}
      </ul>
    </div>
  </div>

  {{#if drafting_model.roadmap.warningParagraphs.length}}
  <div class="callout">
    {{#each drafting_model.roadmap.warningParagraphs}}
    <p>{{this}}</p>
    {{/each}}
  </div>
  {{/if}}
</body>
</html>
