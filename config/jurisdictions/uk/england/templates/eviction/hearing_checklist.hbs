{{!--
  ============================================================================
  HEARING CHECKLIST
  ============================================================================
  Court-facing hearing preparation checklist for England Section 8 cases.
--}}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Hearing Preparation Guide</title>
  <style>
    {{{print_css}}}

    @page {
      size: A4;
      margin: 15mm;
    }

    body {
      margin: 0 auto;
      padding: 0;
      color: #1a1a1a;
      font-size: 10pt;
      line-height: 1.55;
    }

    .header {
      text-align: center;
      margin-bottom: 1.5em;
      padding-bottom: 1em;
      border-bottom: 2px solid #1a1a1a;
    }

    .header h1 {
      margin: 0 0 0.35em 0;
      font-size: 16pt;
    }

    .header h2 {
      margin: 0;
      font-size: 11pt;
      color: #555;
      font-weight: 400;
    }

    .summary-box,
    .timeline-box,
    .section,
    .warning-box {
      page-break-inside: avoid;
      break-inside: avoid;
    }

    .summary-box,
    .timeline-box,
    .warning-box {
      margin-bottom: 1.25em;
      padding: 1em;
      border: 1px solid #d8d8d8;
      background: #fafafa;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: 170px 1fr;
      gap: 0.45em 1em;
    }

    .summary-grid dt {
      font-weight: 600;
    }

    .summary-grid dd {
      margin: 0;
    }

    .section {
      margin-bottom: 1.4em;
    }

    .section h3 {
      margin: 0 0 0.75em 0;
      padding: 0.6em 0.9em;
      background: #1a1a1a;
      color: white;
      font-size: 11pt;
    }

    .checklist {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .checklist li {
      position: relative;
      padding: 0.6em 0 0.6em 1.8em;
      border-bottom: 1px solid #ececec;
    }

    .checklist li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0.72em;
      width: 12px;
      height: 12px;
      border: 1.5px solid #1a1a1a;
      border-radius: 3px;
      background: white;
    }

    .notes {
      margin-top: 0.25em;
      color: #555;
      font-size: 9pt;
    }

    .warning-box {
      background: #fff7ed;
      border-color: #b45309;
    }

    .footer {
      margin-top: 2em;
      padding-top: 1em;
      border-top: 1px solid #d8d8d8;
      font-size: 9pt;
      color: #555;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Hearing Preparation Guide</h1>
    <h2>Prepare the hearing file, updated arrears position, and speaking points for the possession hearing{{#if (contains groundsReliedUpon "Ground 8")}} - with Ground 8 kept under review at both notice and hearing stage{{/if}}</h2>
  </div>

  <div class="summary-box">
    <dl class="summary-grid">
      <dt>Property</dt>
      <dd>{{property_address}}</dd>
      {{#if (hasValue tenant_full_name)}}
      <dt>Tenant</dt>
      <dd>{{tenant_full_name}}{{#if tenant_2_name}}, {{tenant_2_name}}{{/if}}</dd>
      {{/if}}
      {{#if (hasValue court_name)}}
      <dt>Court</dt>
      <dd>{{court_name}}</dd>
      {{/if}}
      <dt>Hearing date</dt>
      <dd><em>To be notified by court</em></dd>
    </dl>
  </div>

  {{#if (or (hasValue notice_service_date) (hasValue notice_expiry_date) (hasValue earliest_proceedings_date))}}
  <div class="timeline-box">
    <h3>Notice timeline</h3>
    {{#if drafting_model.hearingChecklist.overviewParagraphs.length}}
      {{#each drafting_model.hearingChecklist.overviewParagraphs}}
    <p>{{this}}</p>
      {{/each}}
    {{/if}}
    <dl class="summary-grid">
      {{#if (hasValue notice_service_date)}}
      <dt>Notice service date</dt>
      <dd>{{format_date notice_service_date "long"}}</dd>
      {{/if}}
      {{#if (hasValue notice_expiry_date)}}
      <dt>Notice expiry date</dt>
      <dd>{{format_date notice_expiry_date "long"}}</dd>
      {{/if}}
      {{#if (hasValue earliest_proceedings_date)}}
      <dt>Earliest proceedings date</dt>
      <dd>{{format_date earliest_proceedings_date "long"}}</dd>
      {{/if}}
      {{#if (hasValue latest_proceedings_date)}}
      <dt>Latest proceedings date</dt>
      <dd>{{format_date latest_proceedings_date "long"}}</dd>
      {{/if}}
    </dl>
  </div>
  {{/if}}

  <div class="section">
    <h3>What the court will consider</h3>
    <ul class="checklist">
      <li>Is the notice valid?</li>
      <li>Was it served correctly?</li>
      <li>Do the grounds apply?</li>
      <li>Are the arrears proven?</li>
      {{#if (contains groundsReliedUpon "Ground 8")}}
      <li>Does Ground 8 still meet the threshold at the hearing as well as at service stage?</li>
      {{/if}}
    </ul>
  </div>

  <div class="section">
    <h3>Before the hearing</h3>
    <ul class="checklist">
      {{#if drafting_model.hearingChecklist.beforeItems.length}}
        {{#each drafting_model.hearingChecklist.beforeItems}}
      <li>{{this}}</li>
        {{/each}}
      {{else}}
      <li>
        File the court bundle and serve the same bundle on the defendant in accordance with any case directions.
        <div class="notes">Keep proof that the bundle was filed and served.</div>
      </li>
      <li>
        Update the schedule of arrears to the latest practicable date.
        <div class="notes">Ground 8 must usually be satisfied at both notice and hearing stage if you want the mandatory ground to succeed.</div>
      </li>
      <li>
        Check whether the tenant has filed a defence, witness statement, or counterclaim.
        <div class="notes">Be ready to respond briefly and factually.</div>
      </li>
      <li>
        Review the {{notice_name}}, proof of service, witness statement, and bundle index together.
        <div class="notes">The court name, dates, and arrears figure should match across the pack.</div>
      </li>
      {{/if}}
    </ul>
  </div>

  <div class="section">
    <h3>Suggested court bundle order</h3>
    <ul class="checklist">
      <li>N5 claim form</li>
      <li>N119 particulars of claim</li>
      <li>Witness statement</li>
      <li>Tenancy agreement</li>
      <li>Form 3A notice</li>
      <li>N215 or other service evidence</li>
      <li>Arrears schedule</li>
      <li>Rent ledger or bank statements</li>
      <li>Compliance evidence</li>
      <li>Correspondence, photos, and other exhibits</li>
    </ul>
  </div>

  <div class="section">
    <h3>Tenant defence anticipation</h3>
    <ul class="checklist">
      <li>
        Disrepair or set-off.
        <div class="notes">Check inspection history, repair reports, and whether any sum is said to have been withheld or set off.</div>
      </li>
      <li>
        Payments not credited.
        <div class="notes">Check the ledger, bank statements, and the updated arrears schedule before the hearing.</div>
      </li>
      <li>
        Wrong service or wrong date challenge.
        <div class="notes">Check Form 3A, the service record, and every date used in the claim papers.</div>
      </li>
      <li>
        Deposit or compliance challenge.
        <div class="notes">Check the tenancy file for deposit, safety, and service records that may be relevant to credibility or defence points.</div>
      </li>
      <li>
        Hardship or adjournment request.
        <div class="notes">Stay factual and keep the focus on notice validity, service, grounds, and the current arrears position.</div>
      </li>
      <li>
        Counterclaim.
        <div class="notes">Check what has actually been pleaded and what evidence is needed to answer it.</div>
      </li>
    </ul>
  </div>

  <div class="section">
    <h3>Bring to court</h3>
    <ul class="checklist">
      {{#if drafting_model.hearingChecklist.documentItems.length}}
        {{#each drafting_model.hearingChecklist.documentItems}}
      <li>{{this}}</li>
        {{/each}}
      {{else}}
      <li>Your indexed court bundle.</li>
      <li>The original tenancy agreement.</li>
      <li>The original {{notice_name}}.</li>
      <li>The original proof of service certificate or service evidence.</li>
      <li>The updated arrears schedule and any supporting payment records.</li>
      <li>Photo ID and any key correspondence relevant to the grounds relied on.</li>
      {{/if}}
    </ul>
  </div>

  <div class="section">
    <h3>Common failure points</h3>
    <ul class="checklist">
      <li>Inconsistent dates between the notice, N215, witness statement, and claim papers.</li>
      <li>Missing or unclear service evidence.</li>
      <li>Arrears figures that do not match the latest schedule or payment history.</li>
      <li>Issuing before the notice period has expired or before the earliest proceedings date.</li>
      <li>Using the wrong court or the wrong defendant details.</li>
      <li>Signing a statement of truth that does not match the current file.</li>
    </ul>
  </div>

  <div class="section">
    <h3>At the hearing</h3>
    <ul class="checklist">
      {{#if drafting_model.hearingChecklist.atHearingItems.length}}
        {{#each drafting_model.hearingChecklist.atHearingItems}}
      <li>{{this}}</li>
        {{/each}}
      {{else}}
      <li>
        Arrive early, check in with the usher, and keep your bundle open to the notice, service evidence, and arrears figures.
      </li>
      <li>
        Be ready to explain the current arrears, the service timeline, and the evidence supporting each pleaded ground.
      </li>
      <li>
        Keep your answers short, factual, and tied to the documents in the bundle rather than broad allegations.
      </li>
      <li>
        If the tenant raises disrepair, set-off, or a payment proposal, tell the judge what you accept, what you dispute, and which document deals with the point.
      </li>
      {{/if}}
    </ul>
  </div>

  {{#if (or drafting_model.hearingChecklist.warningParagraphs.length (contains groundsReliedUpon "Ground 8"))}}
  <div class="warning-box">
    {{#if drafting_model.hearingChecklist.warningParagraphs.length}}
      {{#each drafting_model.hearingChecklist.warningParagraphs}}
    <p>{{this}}</p>
      {{/each}}
    {{else}}
    <p><strong>Ground 8 reminder:</strong> Ground 8 must usually be satisfied at both notice/service stage and hearing. If payments reduce arrears below the threshold, the mandatory ground may fail and the claim may depend on discretionary grounds.</p>
    {{#if ground8_threshold_label}}
    <p><strong>Threshold reference:</strong> {{ground8_threshold_label}}</p>
    {{/if}}
    {{/if}}
  </div>
  {{/if}}

  <div class="section">
    <h3>Procedural warnings</h3>
    <ul class="checklist">
      <li>Do not issue before expiry or before the earliest proceedings date.</li>
      <li>Verify the court, the claimant names, and the defendant name and address before issue.</li>
      <li>Update the arrears figure before the hearing if payments are made.</li>
      <li>Ensure the N5, N119, notice, and witness statement dates match.</li>
      <li>Do not sign the statement of truth unless the current file is accurate.</li>
    </ul>
  </div>

  <div class="section">
    <h3>If the case changes</h3>
    <ul class="checklist">
      {{#if drafting_model.hearingChecklist.contingencyItems.length}}
        {{#each drafting_model.hearingChecklist.contingencyItems}}
      <li>{{this}}</li>
        {{/each}}
      {{else}}
      <li>
        The tenant attends with a defence.
        <div class="notes">Read it, identify what you accept or dispute, and point the judge to the relevant documents.</div>
      </li>
      <li>
        The tenant makes a partial payment before or at the hearing.
        <div class="notes">Update the arrears figure immediately and reconsider whether Ground 8 still stands.</div>
      </li>
      <li>
        The tenant raises housing disrepair or a counterclaim.
        <div class="notes">Stay factual and explain what notice, inspection, or repair steps are evidenced in your file.</div>
      </li>
      {{/if}}
    </ul>
  </div>

  <div class="footer">
    <p><strong>Date:</strong> {{format_date generated_date "long"}}</p>
    {{#unless clean_output}}
    <p><strong>Landlord Heaven</strong> | Hearing preparation support document</p>
    {{/unless}}
  </div>
</body>
</html>
