{{!--
  ============================================================================
  SCHEDULE OF DEBT (Court-Ready)
  England Possession / Arrears Support Schedule
  ============================================================================
  Court-credible schedule with:
  - Running balance column (for arrears)
  - FIFO payment allocation
  - Clear period-by-period breakdown
  - Dynamic title based on claim type
--}}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{#if arrears_schedule}}Schedule of Rent Arrears{{else}}Schedule of Debt{{/if}}</title>
  <style>
    {{{print_css}}}

    /* ===== @PAGE OVERRIDE ===== */
    @page {
      size: A4;
      margin: 10mm;
    }

    body {
      padding: 0;
      margin: 0 auto;
      font-family: Arial, sans-serif;
      font-size: 10pt;
      line-height: 1.5;
      color: #1a1a1a;
    }

    /* Document Header */
    .doc-header {
      text-align: center;
      margin-bottom: 1.5em;
      padding-bottom: 1em;
      border-bottom: 2px solid #1a1a1a;
    }

    .doc-header h1 {
      font-size: 14pt;
      font-weight: 600;
      margin: 0 0 0.5em 0;
      line-height: 1.3;
      color: #1a1a1a;
    }

    .doc-badge {
      display: inline-block;
      background: #1a1a1a;
      color: white;
      padding: 0.3em 0.8em;
      font-size: 10pt;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    /* Case Details Box */
    .case-details {
      border: 2px solid #1a1a1a;
      padding: 1em;
      margin: 1.5em 0;
      background: #fafafa;
    }

    .case-details-grid {
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: 0.4em 1em;
      font-size: 10pt;
    }

    .case-details-grid dt {
      font-weight: 600;
      color: #444;
    }

    .case-details-grid dd {
      margin: 0;
      color: #1a1a1a;
    }

    /* Summary Box */
    .summary-box {
      border: 2px solid #1a1a1a;
      padding: 1em;
      margin: 1.5em 0;
      background: #f0f9ff;
    }

    .summary-box h3 {
      margin: 0 0 0.8em 0;
      font-size: 11pt;
      font-weight: 600;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.8em 2em;
    }

    .summary-item {
      padding: 0.6em;
      background: white;
      border: 1px solid #ddd;
    }

    .summary-item dt {
      font-size: 9pt;
      color: #666;
      margin-bottom: 0.2em;
    }

    .summary-item dd {
      margin: 0;
      font-size: 11pt;
      font-weight: 600;
    }

    /* Arrears Table */
    .arrears-table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.2em 0;
      font-size: 8.5pt;
      table-layout: fixed;
    }

    .arrears-table th,
    .arrears-table td {
      padding: 5px 6px;
      border: 1px solid #1a1a1a;
      text-align: left;
      vertical-align: top;
    }

    .arrears-table th {
      background: #1a1a1a;
      color: white;
      font-weight: 600;
      white-space: nowrap;
    }

    .arrears-table td {
      background: #fff;
    }

    .arrears-table tr:nth-child(even) td {
      background: #f9fafb;
    }

    .arrears-table .amount {
      text-align: right;
      font-family: 'Courier New', monospace;
    }

    .arrears-table .period-col {
      width: 25%;
    }

    .arrears-table .date-col {
      width: 18%;
      white-space: nowrap;
    }

    .arrears-table .due-col {
      width: 13%;
    }

    .arrears-table .paid-col {
      width: 12%;
    }

    .arrears-table .arrears-col {
      width: 13%;
    }

    .arrears-table .balance-col {
      width: 19%;
    }

    /* Total Row */
    .total-row {
      background: #1a1a1a !important;
      color: white;
      font-weight: 700;
    }

    .total-row td {
      background: #1a1a1a !important;
      color: white !important;
      border-color: #1a1a1a;
    }

    /* Info Box */
    .info-box {
      background: #f8f8f8;
      border-left: 4px solid #1a1a1a;
      padding: 1em;
      margin: 1.5em 0;
      font-size: 10pt;
    }

    /* Document Footer */
    .doc-footer {
      margin-top: 2em;
      padding-top: 1em;
      border-top: 2px solid #e5e7eb;
      font-size: 9pt;
      color: #6b7280;
    }

    .doc-footer p {
      margin: 0.3em 0;
    }

    @media print {
      .arrears-table {
        page-break-inside: avoid;
      }
    }
  </style>
</head>
<body>

<!-- Document Header -->
<div class="doc-header">
  <h1>{{#if arrears_schedule}}Schedule of Rent Arrears{{else}}Schedule of Debt{{/if}}</h1>
  <span class="doc-badge">{{#if pack_context_label}}{{pack_context_label}}{{else}}Possession support schedule{{/if}}</span>
</div>

<!-- Case Details -->
<div class="case-details">
  <dl class="case-details-grid">
    <dt>Property:</dt>
    <dd>{{property_address}}</dd>
    <dt>Defendant:</dt>
    <dd>{{tenant_full_name}}{{#unless tenant_full_name}}{{tenant_name}}{{#unless tenant_name}}{{tenant1_name}}{{/unless}}{{/unless}}{{#if tenant_2_name}}, {{tenant_2_name}}{{/if}}</dd>
    <dt>Claimant:</dt>
    <dd>{{landlord_full_name}}{{#unless landlord_full_name}}{{landlord_name}}{{#unless landlord_name}}{{claimant_name}}{{/unless}}{{/unless}}{{#if landlord_2_name}}, {{landlord_2_name}}{{/if}}</dd>
    {{#if claimant_reference}}
    <dt>Claim Reference:</dt>
    <dd>{{claimant_reference}}</dd>
    {{/if}}
    <dt>Schedule Date:</dt>
    <dd>{{generation_date}}</dd>
  </dl>
</div>

<!-- Arrears Summary -->
<div class="summary-box">
  <h3>{{#if arrears_position_heading}}{{arrears_position_heading}}{{else}}Arrears Summary{{/if}}</h3>
  {{#if arrears_position_note}}
  <p>{{arrears_position_note}}</p>
  {{/if}}
  <div class="summary-grid">
    <div class="summary-item">
      <dt>Rent Amount</dt>
      <dd>{{currency rent_amount}} {{rent_frequency}}</dd>
    </div>
    <div class="summary-item">
      <dt>Due Day</dt>
      <dd>{{#if payment_day}}{{payment_day}}{{ordinal_suffix payment_day}} of each {{#if (eq rent_frequency "monthly")}}month{{else}}{{rent_frequency}} period{{/if}}{{#if usual_payment_weekday}} ({{usual_payment_weekday}}){{/if}}{{else}}Per tenancy agreement{{/if}}</dd>
    </div>
    <div class="summary-item">
      <dt>Tenancy Start Date</dt>
      <dd>{{tenancy_start_date}}</dd>
    </div>
    <div class="summary-item">
      <dt>Total Arrears Claimed</dt>
      <dd><strong>{{currency arrears_total}}</strong></dd>
    </div>
    {{#if periods_missed}}
    <div class="summary-item">
      <dt>Periods Missed</dt>
      <dd><strong>{{periods_missed}}</strong></dd>
    </div>
    {{/if}}
  </div>
</div>

<!-- Arrears Schedule Table with Running Balance -->
<table class="arrears-table">
  <thead>
    <tr>
      <th class="period-col">Period</th>
      <th class="date-col">Due Date</th>
      <th class="amount due-col">Rent Due</th>
      <th class="amount paid-col">Paid</th>
      <th class="amount arrears-col">Arrears</th>
      <th class="amount balance-col">Running Balance</th>
    </tr>
  </thead>
  <tbody>
    {{#each arrears_schedule}}
    <tr>
      <td class="period-col">{{period}}</td>
      <td class="date-col">{{due_date}}</td>
      <td class="amount due-col">{{currency amount_due}}</td>
      <td class="amount paid-col">{{currency amount_paid}}</td>
      <td class="amount arrears-col">{{currency arrears}}</td>
      <td class="amount balance-col"><strong>{{currency running_balance}}</strong></td>
    </tr>
    {{/each}}
    <tr class="total-row">
      <td colspan="4"><strong>Total Arrears Outstanding</strong></td>
      <td class="amount"><strong>{{currency arrears_total}}</strong></td>
      <td class="amount"><strong>{{currency arrears_total}}</strong></td>
    </tr>
  </tbody>
</table>

<!-- Payment Allocation Note -->
<div class="info-box">
  <strong>Payment Allocation Method:</strong> Payments have been allocated using the FIFO (First In, First Out) method, applying payments to the oldest outstanding rent periods first. This is the standard court-accepted method for arrears allocation.
</div>

<!-- Evidence Note -->
<div class="info-box">
  <strong>Evidence Requirements:</strong> Attach proof of payments received, bank statements, and rent ledgers behind this schedule. The County Court expects a clear period-by-period breakdown matching the tenancy rent frequency.
</div>

<!-- Footer -->
<div class="doc-footer">
  <p><strong>Generated:</strong> {{format_date generation_date "long"}}</p>
  {{#unless clean_output}}
  <p><strong>{{#if pack_context_label}}{{pack_context_label}}{{else}}Landlord Heaven Possession Pack{{/if}}</strong> | England</p>
  <p><em>{{#if schedule_role_note}}{{schedule_role_note}}{{else}}This schedule supports the pleaded arrears case and any later possession claim.{{/if}}</em></p>
  {{/unless}}
</div>

</body>
</html>
