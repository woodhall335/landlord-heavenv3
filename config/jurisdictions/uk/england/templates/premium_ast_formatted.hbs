{{!--
  Premium England tenancy agreement template with clause markers for verifier parity.
--}}

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Premium Assured Periodic Tenancy Agreement</title>
  <style>
    @page { size: A4; margin: 25mm 20mm 25mm 20mm; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Georgia", "Times New Roman", serif; font-size: 11pt; line-height: 1.5; color: #1a1a1a; background: white; font-variant-ligatures: none; font-feature-settings: "liga" 0, "clig" 0; }
    h1, h2, h3, h4 { font-family: "Arial", "Helvetica", sans-serif; font-weight: 600; margin-top: 0; page-break-after: avoid; }
    h1 { font-size: 18pt; text-align: center; margin-bottom: 6pt; text-transform: uppercase; letter-spacing: 1pt; }
    h2 { font-size: 13pt; border-bottom: 1pt solid #333; padding-bottom: 4pt; margin: 20pt 0 12pt 0; text-transform: uppercase; }
    h3 { font-size: 11pt; margin: 14pt 0 8pt 0; }
    p { margin: 0 0 8pt 0; text-align: left; hyphens: none; -webkit-hyphens: none; word-break: normal; overflow-wrap: break-word; }
    .doc-header { text-align: center; border-bottom: 2pt solid #333; padding-bottom: 15pt; margin-bottom: 20pt; }
    .doc-subtitle { font-size: 10pt; color: #555; margin: 5pt 0; }
    .doc-date { font-size: 10pt; margin-top: 10pt; }
    .premium-badge { display: inline-block; background: linear-gradient(135deg, #2c5282 0%, #2d3748 100%); color: white; padding: 4pt 12pt; font-size: 9pt; text-transform: uppercase; letter-spacing: 1px; margin: 8pt 0 0 0; white-space: nowrap; }
    .parties-section { margin: 15pt 0; }
    .party-block { margin: 10pt 0; padding-left: 20pt; }
    .party-role { font-weight: bold; text-transform: uppercase; font-size: 9pt; letter-spacing: 0.5pt; margin-bottom: 3pt; }
    .party-details-text { line-height: 1.6; word-break: normal; overflow-wrap: break-word; }
    .definitions-list { list-style: none; margin: 0; padding: 0; }
    .definitions-list li { margin: 6pt 0; }
    .defined-term { font-weight: bold; }
    .clause { margin: 8pt 0; padding-left: 30pt; text-indent: -30pt; }
    .clause-num { display: inline-block; width: 28pt; font-weight: bold; }
    .premium-section { border-left: 3pt solid #2c5282; padding-left: 12pt; margin: 15pt 0; page-break-inside: avoid; }
    .premium-label { font-size: 8pt; color: #2c5282; text-transform: uppercase; letter-spacing: 0.5pt; margin-bottom: 5pt; font-weight: bold; }
    .legal-notice { border: 1pt solid #333; padding: 10pt; margin: 12pt 0; background: #fffef5; page-break-inside: avoid; }
    .legal-notice-title { font-weight: bold; font-size: 10pt; margin-bottom: 6pt; text-transform: uppercase; }
    .warning-box { border: 1pt solid #8b5e00; padding: 10pt; margin: 12pt 0; background: #fff8e6; page-break-inside: avoid; }
    .warning-title { font-weight: bold; font-size: 10pt; margin-bottom: 6pt; text-transform: uppercase; color: #8b5e00; }
    .data-table { width: 100%; border-collapse: collapse; margin: 12pt 0; font-size: 10pt; page-break-inside: avoid; }
    .data-table th, .data-table td { border: 0.5pt solid #666; padding: 6pt 8pt; text-align: left; vertical-align: top; }
    .data-table th { background: #f5f5f5; font-weight: bold; font-size: 9pt; text-transform: uppercase; }
    .data-table td.label { width: 35%; font-weight: 500; background: #fafafa; }
    .data-table td.value { width: 65%; word-wrap: break-word; overflow-wrap: break-word; word-break: normal; }
    .schedule { page-break-before: always; margin-top: 0; }
    .schedule-header { text-align: center; border: 1pt solid #333; padding: 10pt; margin-bottom: 15pt; background: #f8f8f8; }
    .schedule-header h2 { border: none; margin: 0; padding: 0; }
    .schedule-title { font-size: 12pt; margin-top: 5pt; font-weight: normal; text-transform: none; }
    .signature-section { page-break-before: always; page-break-inside: avoid; margin-top: 0; padding-top: 20pt; }
    .signature-block { margin: 25pt 0; page-break-inside: avoid; }
    .signature-role { font-weight: bold; text-transform: uppercase; font-size: 9pt; margin-bottom: 8pt; }
    .signature-name { margin-bottom: 20pt; }
    .signature-line { border-bottom: 1pt solid #333; width: 250pt; height: 25pt; }
    .signature-label { font-size: 9pt; color: #555; margin-top: 3pt; }
    .signature-date-line { border-bottom: 1pt solid #333; width: 150pt; display: inline-block; margin-left: 10pt; }
    .witness-section { margin-top: 30pt; padding: 14pt; border: 1pt solid #999; background: #fafafa; page-break-inside: avoid; break-inside: avoid; }
    .witness-block { page-break-inside: avoid; break-inside: avoid; }
    .witness-title { font-weight: bold; font-size: 10pt; margin-bottom: 8pt; text-transform: uppercase; }
    .footer-info { margin-top: 40pt; padding-top: 15pt; border-top: 0.5pt solid #999; font-size: 8pt; color: #666; text-align: center; page-break-inside: avoid; clear: both; }
    .doc-footer { margin-top: 40pt; padding-top: 15pt; border-top: 0.5pt solid #999; font-size: 8pt; color: #666; text-align: center; page-break-inside: avoid; clear: both; }
    ul, ol { margin: 6pt 0 6pt 25pt; padding: 0; }
    li { margin: 4pt 0; }
    h2, h3, h4 { page-break-after: avoid; orphans: 3; widows: 3; }
    p, li { orphans: 3; widows: 3; }
    .page-break { page-break-before: always; height: 0; margin: 0; padding: 0; }
    @media print {
      .schedule, .page-break, .signature-section { page-break-before: always; }
      .signature-section, .signature-block, .witness-section, .witness-block, .legal-notice, .warning-box, .schedule-header, .footer-info, .doc-footer { page-break-inside: avoid; }
      .data-table, .data-table tr { page-break-inside: avoid; }
    }
  </style>
</head>
<body>
  <div class="doc-header">
    <h1>Assured Periodic Tenancy Agreement</h1>
    <div class="doc-subtitle">Premium Assured Periodic Tenancy Agreement</div>
    <div class="doc-subtitle">England private rented sector tenancy</div>
    <div class="doc-subtitle">England</div>
    <div class="premium-badge">Premium Edition</div>
    <div class="doc-date">Dated: <strong>{{formatUKDate agreement_date}}</strong></div>
  </div>

  {{#if england_reform_warning}}
  <div class="warning-box">
    <div class="warning-title">England Tenancy Position</div>
    <p>{{england_reform_warning}}</p>
  </div>
  {{/if}}

  <h2>1. Parties</h2>
  <div class="parties-section">
    <div class="party-block">
      <div class="party-role">Landlord</div>
      <div class="party-details-text"><strong>{{landlord_full_name}}</strong><br>{{landlord_address}}<br>{{landlord_email}} | {{landlord_phone}}</div>
    </div>
    {{#if agent_name}}
    <div class="party-block">
      <div class="party-role">Landlord's Agent</div>
      <div class="party-details-text"><strong>{{agent_name}}</strong><br>{{agent_address}}<br>{{agent_email}} | {{agent_phone}}</div>
    </div>
    {{/if}}
    <div class="party-block">
      <div class="party-role">Tenant{{#if multiple_tenants}}s{{/if}}</div>
      <div class="party-details-text">
        {{#each tenants}}
        <strong>{{this.full_name}}</strong>{{#if this.dob}} (DOB: {{formatUKDate this.dob}}){{/if}}<br>
        {{this.email}}{{#if this.phone}} | {{this.phone}}{{/if}}{{#unless @last}}<br><br>{{/unless}}
        {{/each}}
      </div>
    </div>
    {{#if guarantor_name}}
    <div class="party-block">
      <div class="party-role">Guarantor</div>
      <div class="party-details-text"><strong>{{guarantor_name}}</strong><br>{{guarantor_address}}<br>{{guarantor_email}} | {{guarantor_phone}}{{#if guarantor_dob}}<br>DOB: {{formatUKDate guarantor_dob}}{{/if}}{{#if guarantor_relationship}}<br>Relationship: {{guarantor_relationship}}{{/if}}</div>
    </div>
    {{/if}}
  </div>

  <h2>2. Definitions and Interpretation</h2>
  <ul class="definitions-list">
    <li><span class="defined-term">"Agreement"</span> means this assured periodic tenancy agreement and the Schedules attached to it.</li>
    <li><span class="defined-term">"Property"</span> means {{property_address}} together with the contents and common parts described in this Agreement.</li>
    <li><span class="defined-term">"Tenant"</span> means {{#each tenants}}{{this.full_name}}{{#unless @last}}, {{/unless}}{{/each}}{{#if multiple_tenants}} jointly and severally{{/if}}.</li>
    <li><span class="defined-term">"Rent"</span> means the sum of &pound;{{rent_amount}} per {{rent_period}} payable in accordance with this Agreement.</li>
    <li><span class="defined-term">"Deposit"</span> means the tenancy deposit of &pound;{{deposit_amount}}.</li>
    <li><span class="defined-term">"Inventory"</span> means any schedule of condition or inventory supplied at check-in.</li>
    <li><span class="defined-term">"Written Notice"</span> means notice in writing sent by hand, post, or email.</li>
    <li><span class="defined-term">"Term"</span> means the periodic tenancy commencing on {{formatUKDate tenancy_start_date}} and continuing until ended in accordance with statute and this Agreement.</li>
  </ul>
  <p>Words importing the singular include the plural. References to statute include statutory modification or replacement. Where there is more than one Tenant, each Tenant is liable for the whole of the Tenant covenants.</p>

  <!-- CLAUSE:CORE_TENANCY -->
  <h2>3. Letting and Term</h2>
  <p class="clause"><span class="clause-num">3.1</span> The Landlord lets the Property to the Tenant for use as a private residence only.</p>
  <p class="clause"><span class="clause-num">3.2</span> The Tenant is granted exclusive occupation of the Property, subject to the Landlord's rights of access contained in this Agreement and any rights affecting communal areas.</p>
  <p class="clause"><span class="clause-num">3.3</span> The tenancy begins on <strong>{{formatUKDate tenancy_start_date}}</strong> as a periodic assured tenancy under the law in force in England at that date.</p>
  <p class="clause"><span class="clause-num">3.4</span> This tenancy does not have a fixed end date and continues until ended in accordance with statute.</p>
  <p class="clause"><span class="clause-num">3.5</span> The Landlord may only seek possession where a lawful statutory ground applies, including any relevant rent arrears, anti-social behaviour, sale, landlord occupation, or other statutory ground in force at the relevant time.</p>
  <p class="clause"><span class="clause-num">3.6</span> The Landlord may only recover possession or terminate the tenancy through the court-led statutory process in force at the relevant time and by obtaining any court order required by law.</p>
  <p class="clause"><span class="clause-num">3.7</span> The Tenant has the right to remain in the Property unless and until the Landlord establishes a lawful statutory ground for possession and obtains any court order required by law.</p>
  <p class="clause"><span class="clause-num">3.8</span> The Tenant may end the tenancy by giving written notice in accordance with the statutory requirements in force at the relevant time.</p>

  <h2>4. Rent</h2>
  <p class="clause"><span class="clause-num">4.1</span> The Tenant shall pay the Rent of <strong>&pound;{{rent_amount}}</strong> per {{rent_period}} in advance on the <strong>{{rent_due_day}}</strong> of each {{rent_period}}.</p>
  <p class="clause"><span class="clause-num">4.2</span> Payment shall be made by {{payment_method}} to the account specified in Schedule 2.</p>
  <p class="clause"><span class="clause-num">4.3</span> The first payment is due on or before {{formatUKDate tenancy_start_date}}.</p>
  <div class="premium-section">
    <div class="premium-label">Premium: Rent Administration</div>
    <p class="clause"><span class="clause-num">4.4</span> If rent remains unpaid for 14 days after the due date, interest may accrue on the overdue sum at 3% above the Bank of England base rate per annum, so far as lawful.</p>
    <p class="clause"><span class="clause-num">4.5</span> If the Landlord proposes a new rent, the Landlord will serve notice in accordance with section 13 of the Housing Act 1988 or any replacement statutory procedure in force at the relevant time. Nothing in this Agreement authorises a prohibited fee or charge.</p>
  </div>

  <h2>5. Deposit</h2>
  <p class="clause"><span class="clause-num">5.1</span> The Tenant has paid a Deposit of <strong>&pound;{{deposit_amount}}</strong>.</p>
  <p class="clause"><span class="clause-num">5.2</span> The Landlord will protect the Deposit in {{deposit_scheme_name}} within 30 days of receipt and provide the prescribed information.</p>
  <p class="clause"><span class="clause-num">5.3</span> The Deposit may be applied only to lawful claims including unpaid rent, damage beyond fair wear and tear, cleaning costs where the Property is not returned to the same standard of cleanliness, missing items, or other losses arising from breach of this Agreement.</p>
  <p class="clause"><span class="clause-num">5.4</span> Any dispute concerning deductions may be referred to the deposit scheme alternative dispute resolution process.</p>

  <!-- CLAUSE:TENANT_OBLIGATIONS -->
  <h2>6. Tenant Obligations</h2>
  <p class="clause"><span class="clause-num">6.1</span> Pay the Rent and all other sums due under this Agreement on time.</p>
  <p class="clause"><span class="clause-num">6.2</span> Keep the Property reasonably clean, heated, ventilated, and in tenant-like condition.</p>
  <p class="clause"><span class="clause-num">6.3</span> Promptly report any disrepair, damage, infestation, or safety issue to the Landlord or Agent using the reporting method stated in Schedule 6.</p>
  <p class="clause"><span class="clause-num">6.4</span> Permit access on at least 24 hours' notice for inspection, repair, valuation, compliance checks, or viewings at the end of the tenancy, except in emergency.</p>
  <p class="clause"><span class="clause-num">6.5</span> Not make structural or decorative alterations without prior written consent.</p>
  <p class="clause"><span class="clause-num">6.6</span> Return the Property at the end of the tenancy in the same standard of cleanliness and repair as at the start, fair wear and tear excepted, together with all keys and access devices.</p>

  <!-- CLAUSE:PETS_CLAUSE -->
  <div class="premium-section">
    <div class="premium-label">Premium: Pets</div>
    <p class="clause"><span class="clause-num">6.7</span> {{#if pets_allowed}}The following pet arrangements are authorised: {{#if approved_pets}}{{approved_pets}}{{else}}approved domestic pet(s) described in writing between the parties{{/if}}. Any authorised pet is permitted subject to this Agreement and any lawful reasonable conditions the Landlord may impose in writing, having regard to the request and the suitability of the Property.{{else}}No pet may be kept at the Property without the Landlord's prior written consent. Consent is not to be unreasonably refused where the request is reasonable and the Property is suitable. The Landlord may impose lawful reasonable conditions in writing, having regard to the type, number, and size of the pet and the suitability of the Property.{{/if}}</p>
    <p class="clause"><span class="clause-num">6.8</span> The Tenant remains responsible for any pet-related damage, nuisance, fouling, infestation, smell, scratching, staining, or other related loss. The Landlord may require reasonable cleaning, treatment, or remediation where needed to restore the Property to the standard required by this Agreement, but nothing in this clause requires a prohibited payment or mandatory professional cleaning in every case.</p>
  </div>

  <!-- CLAUSE:ANTI_SUBLET -->
  <p class="clause"><span class="clause-num">6.9</span> The Tenant must not sublet, assign, part with possession, grant room licences, or allow short-term letting platform use without the Landlord's prior written consent.</p>

  <h2>7. Landlord Obligations</h2>
  <p class="clause"><span class="clause-num">7.1</span> Permit the Tenant quiet enjoyment of the Property without unlawful interruption.</p>
  <p class="clause"><span class="clause-num">7.2</span> Keep in repair the structure and exterior and the installations for water, gas, electricity, sanitation, space heating, and hot water, in accordance with section 11 of the Landlord and Tenant Act 1985 and any other applicable duty.</p>
  <p class="clause"><span class="clause-num">7.3</span> Comply with duties relating to gas safety, electrical safety, smoke alarms, carbon monoxide alarms, and deposit protection.</p>
  <p class="clause"><span class="clause-num">7.4</span> Provide the Tenant with the documents and information required by law for the tenancy regime applying at the start date, including information about the tenant notice requirements, the section 13 rent increase route or any replacement statutory route in force at the relevant time, the landlord possession process, the pets position, bills handling, any England statutory tenant information or government guidance required by law for the tenancy route, the EPC, Gas Safety Certificate, EICR where required, and deposit prescribed information.</p>
  <p class="clause"><span class="clause-num">7.5</span> Carry out Right to Rent checks under the Immigration Act 2014 where required. Nothing in this Agreement makes the Tenant responsible for the Landlord's statutory compliance.</p>

  {{#if multiple_tenants}}
  <!-- CLAUSE:JOINT_LIABILITY -->
  <div class="legal-notice">
    <div class="legal-notice-title">Joint and Several Liability</div>
    <p>Where there is more than one Tenant, each Tenant is jointly and severally liable for the whole of the rent and all Tenant obligations. The Landlord may pursue any one or more of them for the full liability.</p>
  </div>
  {{/if}}

  <!-- CLAUSE:SHARED_FACILITIES -->
  <h2>8. HMO &amp; Shared Facilities</h2>
  <p class="clause"><span class="clause-num">8.1</span> The Property is occupied on a multi-occupancy basis with shared access to {{#if communal_areas}}{{communal_areas}}{{else}}the kitchen, bathrooms, circulation areas, and any common facilities{{/if}}.</p>
  <p class="clause"><span class="clause-num">8.2</span> The Tenant shall use shared facilities reasonably, keep them clean after use, avoid obstruction of hallways or fire escape routes, and respect the rights of other occupiers.</p>
  <p class="clause"><span class="clause-num">8.3</span> House rules for cleaning, refuse disposal, noise, guests, security, and shared appliances are set out in Schedule 5 and form part of this Agreement.</p>
  <p class="clause"><span class="clause-num">8.4</span> The Tenant must not allow any person to occupy the Property or any part of it beyond the permitted occupancy arrangements without written consent.</p>

  <!-- CLAUSE:HMO_LICENSING -->
  <div class="premium-section">
    <div class="premium-label">Premium: HMO Licensing and Safety</div>
    <p class="clause"><span class="clause-num">8.5</span> {{#if hmo_licence_status}}HMO licensing status: <strong>{{hmo_licence_status}}</strong>.{{else}}The Landlord will comply with any HMO licensing obligations applying to the Property.{{/if}}</p>
    <p class="clause"><span class="clause-num">8.6</span> HMO licence reference: <strong>{{#if hmo_licence_number}}{{hmo_licence_number}}{{else}}TO BE COMPLETED BEFORE SIGNING{{/if}}</strong>{{#if hmo_licence_expiry}} (expiry {{formatUKDate hmo_licence_expiry}}){{/if}}.</p>
    <p class="clause"><span class="clause-num">8.7</span> The Tenant shall not tamper with smoke alarms, carbon monoxide alarms, emergency lighting, fire doors, extinguishers, or any other safety equipment and shall keep all escape routes clear.</p>
  </div>

  {{#if guarantor_name}}
  <!-- CLAUSE:GUARANTOR -->
  <h2>9. Guarantor Agreement</h2>
  <div class="warning-box">
    <div class="warning-title">Notice to Guarantor</div>
    <p>By signing this Agreement the Guarantor gives a legally binding guarantee and should take independent legal advice before signing.</p>
  </div>
  <p class="clause"><span class="clause-num">9.1</span> The Guarantor guarantees the payment of the Rent and the performance of the Tenant obligations and agrees to indemnify the Landlord against losses arising from any breach of them.</p>
  <p class="clause"><span class="clause-num">9.2</span> The Landlord may pursue the Guarantor directly, without first taking action against the Tenant or any other person liable under this Agreement.</p>
  <p class="clause"><span class="clause-num">9.3</span> This is a continuing guarantee. It applies to this tenancy and to any lawful continuation, statutory continuation, renewal, replacement, or variation of it unless and until the Landlord expressly releases the Guarantor in writing.</p>
  <p class="clause"><span class="clause-num">9.4</span> The Guarantor's liability is capped at {{#if guarantor_max_liability}}{{guarantor_max_liability}}{{else}}twelve months' rent together with reasonable enforcement costs{{/if}}, save for liabilities already accrued before any written release.</p>
  <p class="clause"><span class="clause-num">9.5</span> The Guarantor confirms receipt of sufficient information about the tenancy and is advised to take independent legal advice before signing.</p>
  {{/if}}

  <h2>{{#if guarantor_name}}10{{else}}9{{/if}}. General Provisions</h2>
  <p class="clause"><span class="clause-num">{{#if guarantor_name}}10{{else}}9{{/if}}.1</span> This Agreement contains the contractual terms agreed between the parties, subject to all overriding statutory rights and obligations.</p>
  <p class="clause"><span class="clause-num">{{#if guarantor_name}}10{{else}}9{{/if}}.2</span> No variation is effective unless recorded in writing and signed by or on behalf of the parties affected.</p>
  <p class="clause"><span class="clause-num">{{#if guarantor_name}}10{{else}}9{{/if}}.3</span> If any provision is unenforceable, the remaining provisions continue so far as lawful.</p>
  <p class="clause"><span class="clause-num">{{#if guarantor_name}}10{{else}}9{{/if}}.4</span> This Agreement is governed by the law of England and Wales and the parties submit to the jurisdiction of the courts of England and Wales where applicable.</p>
  <p class="clause"><span class="clause-num">{{#if guarantor_name}}10{{else}}9{{/if}}.5</span> Notices may be served by hand, post, or email to the addresses stated in this Agreement unless statute requires a different method.</p>

  {{> statutory_acknowledgements jurisdiction="england" format="html" heading_style="h2"}}

  <div class="signature-section">
    <h2>Signatures</h2>
    <p>By signing below, the parties confirm that they have read, understood, and agree to be bound by this Agreement and the attached Schedules.</p>
    <div class="signature-block">
      <div class="signature-role">Landlord</div>
      <div class="signature-name">Name: {{landlord_full_name}}</div>
      <div class="signature-line"></div>
      <div class="signature-label">Signature</div>
      <div style="margin-top: 10pt;">Date: <span class="signature-date-line"></span></div>
    </div>
    {{#if agent_name}}
    <div class="signature-block">
      <div class="signature-role">Agent</div>
      <div class="signature-name">Name: {{agent_name}}</div>
      <div class="signature-line"></div>
      <div class="signature-label">Signature (for and on behalf of the Landlord)</div>
      <div style="margin-top: 10pt;">Date: <span class="signature-date-line"></span></div>
    </div>
    {{/if}}
    {{#each tenants}}
    <div class="signature-block">
      <div class="signature-role">Tenant {{add @index 1}}</div>
      <div class="signature-name">Name: {{this.full_name}}</div>
      <div class="signature-line"></div>
      <div class="signature-label">Signature</div>
      <div style="margin-top: 10pt;">Date: <span class="signature-date-line"></span></div>
    </div>
    {{/each}}
    {{#if guarantor_name}}
    <div class="signature-block">
      <div class="signature-role">Guarantor</div>
      <div class="signature-name">Name: {{guarantor_name}}</div>
      <div class="signature-line"></div>
      <div class="signature-label">Signature</div>
      <div style="margin-top: 10pt;">Date: <span class="signature-date-line"></span></div>
    </div>
    {{/if}}
    <div class="witness-section" style="page-break-inside: avoid; break-inside: avoid;">
      <div class="witness-block">
        <div class="witness-title">Witness</div>
        <p>A witness is not generally required for an England residential tenancy agreement, but witnessing may help with evidential authenticity if the document is later disputed.</p>
        <p><strong>Witness Name:</strong> _________________________________</p>
        <p><strong>Witness Address:</strong> _________________________________</p>
        <p><strong>Witness Signature:</strong> _________________________________</p>
        <p><strong>Date:</strong> _________________________________</p>
      </div>
    </div>
  </div>

  <section class="schedule">
    <div class="schedule-header">
      <h2>Schedule 1</h2>
      <div class="schedule-title">Property Details</div>
    </div>
    <table class="data-table">
      <tr><td class="label">Property Address</td><td class="value">{{property_address}}</td></tr>
      {{#if property_type}}<tr><td class="label">Property Type</td><td class="value">{{property_type}}</td></tr>{{/if}}
      {{#if number_of_bedrooms}}<tr><td class="label">Bedrooms</td><td class="value">{{number_of_bedrooms}}</td></tr>{{/if}}
      {{#if furnished_status}}<tr><td class="label">Furnished Status</td><td class="value">{{furnished_status}}</td></tr>{{/if}}
      {{#if parking_available}}<tr><td class="label">Parking</td><td class="value">{{#if parking_details}}{{parking_details}}{{else}}Included{{/if}}</td></tr>{{/if}}
      {{#if epc_rating}}<tr><td class="label">EPC Rating</td><td class="value">{{epc_rating}}{{#if epc_expiry}} (valid until {{formatUKDate epc_expiry}}){{/if}}</td></tr>{{/if}}
    </table>
  </section>

  <section class="schedule">
    <div class="schedule-header">
      <h2>Schedule 2</h2>
      <div class="schedule-title">Rent, Deposit, and Payments</div>
    </div>
    <table class="data-table">
      <tr><td class="label">Rent</td><td class="value">&pound;{{rent_amount}} per {{rent_period}}</td></tr>
      <tr><td class="label">Due Date</td><td class="value">{{rent_due_day}} of each {{rent_period}}</td></tr>
      <tr><td class="label">Payment Method</td><td class="value">{{payment_method}}</td></tr>
      <tr><td class="label">First Payment Date</td><td class="value">{{#if first_payment_date}}{{formatUKDate first_payment_date}}{{else}}{{formatUKDate tenancy_start_date}}{{/if}}</td></tr>
      <tr><td class="label">Deposit</td><td class="value">&pound;{{deposit_amount}} in {{deposit_scheme_name}}</td></tr>
      {{#if bank_account_name}}<tr><td class="label">Account Name</td><td class="value">{{bank_account_name}}</td></tr>{{/if}}
      {{#if bank_sort_code}}<tr><td class="label">Sort Code</td><td class="value">{{bank_sort_code}}</td></tr>{{/if}}
      {{#if bank_account_number}}<tr><td class="label">Account Number</td><td class="value">{{bank_account_number}}</td></tr>{{/if}}
      {{#if payment_details}}<tr><td class="label">Payment Reference / Details</td><td class="value">{{payment_details}}</td></tr>{{/if}}
    </table>
  </section>

  <section class="schedule">
    <div class="schedule-header">
      <h2>Schedule 3</h2>
      <div class="schedule-title">Utilities and Outgoings</div>
    </div>
    <table class="data-table">
      <tr><th>Item</th><th>Responsibility</th><th>Notes</th></tr>
      <tr><td>Council Tax</td><td>{{#if council_tax_responsibility}}{{council_tax_responsibility}}{{else}}Tenant{{/if}}</td><td>{{#if council_tax_band}}Band {{council_tax_band}}{{/if}}</td></tr>
      <tr><td>Gas</td><td>{{#if utilities_responsibility}}{{utilities_responsibility}}{{else}}Tenant{{/if}}</td><td>Register with supplier</td></tr>
      <tr><td>Electricity</td><td>{{#if utilities_responsibility}}{{utilities_responsibility}}{{else}}Tenant{{/if}}</td><td>Register with supplier</td></tr>
      <tr><td>Water</td><td>{{#if utilities_responsibility}}{{utilities_responsibility}}{{else}}Tenant{{/if}}</td><td></td></tr>
      <tr><td>Internet</td><td>{{#if internet_responsibility}}{{internet_responsibility}}{{else}}Tenant{{/if}}</td><td></td></tr>
      <tr><td>Buildings Insurance</td><td>Landlord</td><td>Tenant to insure own contents</td></tr>
    </table>
  </section>

  <section class="schedule">
    <div class="schedule-header">
      <h2>Schedule 4</h2>
      <div class="schedule-title">Inventory and Condition</div>
    </div>
    {{#if inventory_attached}}
    <p>An inventory and schedule of condition is attached or separately supplied and forms part of this Agreement.</p>
    {{else}}
    <p>{{#if inventory_provided}}An inventory will be supplied at or before check-in.{{else}}The parties should record the condition of the Property at check-in with photographs and written notes.{{/if}}</p>
    {{/if}}
    <p>The check-out comparison will assess return of the Property to the same standard of cleanliness and condition, fair wear and tear excepted.</p>
  </section>

  <section class="schedule">
    <div class="schedule-header">
      <h2>Schedule 5</h2>
      <div class="schedule-title">House Rules and Shared Occupation Protocol</div>
    </div>
    <p>Quiet hours apply from 11 pm to 7 am. Guests are permitted only on a temporary basis and must not create overcrowding, nuisance, or security risk.</p>
    <p>Smoking inside the Property is {{#if smoking_allowed}}permitted only in the manner specifically authorised by the Landlord{{else}}not permitted{{/if}}.</p>
    <p>Shared areas must be cleaned after use and refuse disposed of properly. {{#if communal_cleaning}}Communal cleaning arrangements: {{communal_cleaning}}.{{/if}}</p>
    {{#if has_garden}}<p>The garden and outside areas must be kept in reasonable order and free from rubbish.</p>{{/if}}
  </section>

  <section class="schedule">
    <div class="schedule-header">
      <h2>Schedule 6</h2>
      <div class="schedule-title">Statutory Information and Contacts</div>
    </div>
    <table class="data-table">
      <tr><td class="label">Tenant information / government guidance</td><td class="value">Provide any England statutory tenant information or government guidance required by law for the tenancy route, including the Renters' Rights Act Information Sheet 2026 or other prescribed written information where applicable.</td></tr>
      <tr><td class="label">Right to Rent</td><td class="value">{{#if right_to_rent_check_date}}Checks completed on {{formatUKDate right_to_rent_check_date}}.{{else}}Checks to be completed before occupation where required under the Immigration Act 2014.{{/if}}</td></tr>
      <tr><td class="label">Repairs Reporting</td><td class="value">{{#if repairs_reporting_method}}{{repairs_reporting_method}}{{else}}Report repairs promptly to the Landlord or Agent in writing.{{/if}}</td></tr>
      <tr><td class="label">Emergency Contact</td><td class="value">{{#if emergency_contact}}{{emergency_contact}}{{else}}{{#if agent_name}}{{agent_phone}}{{else}}{{landlord_phone}}{{/if}}{{/if}}</td></tr>
      <tr><td class="label">HMO Licence</td><td class="value">{{#if hmo_licence_number}}{{hmo_licence_number}}{{else}}TO BE COMPLETED BEFORE SIGNING{{/if}}</td></tr>
    </table>
  </section>

  <div class="footer-info">
    <p><strong>Premium Assured Periodic Tenancy Agreement</strong></p>
    <p>Generated: {{formatUKDate current_date}} | Reference: {{#if case_id}}{{case_id}}{{else}}{{document_id}}{{/if}}</p>
    <p>England residential landlord document drafted for professional use and updated for the Renters' Rights Act 2025 workflow. The statutory regime applicable at the tenancy start date prevails over inconsistent contractual wording.</p>
  </div>
</body>
</html>

