<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>
    @page {
      size: A4;
      margin: 24mm 18mm 22mm;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      font-size: 11pt;
      line-height: 1.58;
      color: #18181b;
      background: #fff;
    }

    h1, h2, h3 {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      page-break-after: avoid;
      color: #111827;
    }

    .cover {
      border: 1.5pt solid #1f2937;
      padding: 22pt 24pt;
      margin-bottom: 20pt;
    }

    .cover-topline {
      font-family: Arial, Helvetica, sans-serif;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: 8.25pt;
      color: #4b5563;
      margin-bottom: 10pt;
    }

    .cover h1 {
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-size: 20pt;
      line-height: 1.2;
    }

    .cover-subtitle {
      margin-top: 8pt;
      font-size: 11pt;
      color: #374151;
    }

    .cover-intro {
      margin-top: 14pt;
      padding: 12pt 14pt;
      border-left: 3pt solid #374151;
      background: #f8fafc;
      color: #1f2937;
      text-align: justify;
    }

    .cover-meta,
    .parties-table,
    .detail-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 14pt;
      font-size: 10pt;
    }

    .cover-meta td,
    .parties-table td,
    .detail-table td {
      border: 0.75pt solid #9ca3af;
      padding: 8pt 10pt;
      vertical-align: top;
    }

    .cover-meta .label,
    .parties-table .role,
    .detail-table .label {
      width: 28%;
      background: #f3f4f6;
      font-family: Arial, Helvetica, sans-serif;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #374151;
    }

    .section-title {
      font-size: 12.5pt;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      border-bottom: 1pt solid #111827;
      padding-bottom: 5pt;
      margin: 18pt 0 12pt;
    }

    .opening,
    .clause p,
    .clause-intro,
    .execution-copy {
      margin: 0 0 8pt 0;
      text-align: justify;
    }

    .party-name {
      font-weight: 700;
      color: #111827;
    }

    .party-detail {
      margin-top: 3pt;
    }

    .recitals {
      margin: 0 0 8pt 0;
      padding: 0;
      list-style: none;
      counter-reset: recital;
    }

    .recitals li {
      margin: 0 0 7pt 0;
      padding-left: 28pt;
      position: relative;
      text-align: justify;
    }

    .recitals li::before {
      counter-increment: recital;
      content: counter(recital, upper-alpha) ".";
      position: absolute;
      left: 0;
      top: 0;
      font-family: Arial, Helvetica, sans-serif;
      font-weight: 700;
    }

    .clause {
      margin: 14pt 0 0;
      page-break-inside: avoid;
    }

    .clause-heading {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 11.25pt;
      font-weight: 700;
      margin-bottom: 6pt;
      color: #111827;
    }

    .subpoints {
      margin: 6pt 0 8pt 18pt;
      padding: 0;
    }

    .subpoints li {
      margin: 0 0 6pt 0;
      text-align: justify;
    }

    .note-panel {
      margin-top: 14pt;
      padding: 11pt 13pt;
      border: 0.75pt solid #9ca3af;
      background: #f9fafb;
    }

    .note-panel p {
      margin: 6pt 0 0;
      white-space: pre-line;
      text-align: justify;
    }

    .deed-warning {
      margin-top: 12pt;
      padding: 10pt 12pt;
      border: 0.75pt solid #92400e;
      background: #fff7ed;
      color: #7c2d12;
      page-break-inside: avoid;
    }

    .execution {
      margin-top: 24pt;
      page-break-inside: avoid;
    }

    .signatures {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14pt;
    }

    .signature-card {
      border: 0.75pt solid #9ca3af;
      padding: 12pt;
      min-height: 176pt;
      page-break-inside: avoid;
    }

    .signature-role {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 8.75pt;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #4b5563;
    }

    .signature-name {
      margin-top: 5pt;
      font-weight: 700;
      color: #111827;
    }

    .signature-line {
      margin-top: 28pt;
      border-bottom: 1pt solid #1f2937;
      height: 18pt;
    }

    .signature-meta {
      margin-top: 8pt;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 8.75pt;
      color: #4b5563;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12pt;
    }

    .witness-block {
      margin-top: 14pt;
      padding-top: 10pt;
      border-top: 0.75pt dashed #9ca3af;
    }

    .witness-label {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 8.5pt;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #4b5563;
    }

    .witness-note {
      margin-top: 6pt;
      font-size: 8.9pt;
      color: #374151;
      text-align: justify;
    }

    .footer {
      margin-top: 18pt;
      padding-top: 10pt;
      border-top: 0.75pt solid #9ca3af;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 8.5pt;
      color: #6b7280;
      display: flex;
      justify-content: space-between;
      gap: 10pt;
    }

    @media print {
      .section-title,
      .clause-heading,
      .signature-card {
        page-break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <section class="cover">
    <div class="cover-topline">
      {{#if execution_as_deed}}Executed as a deed{{else}}England residential document{{/if}}
    </div>
    <h1>{{title}}</h1>
    <div class="cover-subtitle">{{subtitle}}</div>
    {{#if intro}}<div class="cover-intro">{{intro}}</div>{{/if}}

    <table class="cover-meta">
      <tr>
        <td class="label">Document date</td>
        <td>{{formatUKDate document_date}}</td>
        <td class="label">Reference</td>
        <td>{{document_reference}}</td>
      </tr>
      <tr>
        <td class="label">Effective date</td>
        <td>{{#if effective_date}}{{formatUKDate effective_date}}{{else}}Not stated{{/if}}</td>
        <td class="label">Nature</td>
        <td>{{#if nature_of_document}}{{nature_of_document}}{{else}}Residential agreement{{/if}}</td>
      </tr>
      <tr>
        <td class="label">Property</td>
        <td colspan="3">{{#if property_address}}{{property_address}}{{else}}Not stated{{/if}}</td>
      </tr>
      <tr>
        <td class="label">Tenant(s)</td>
        <td>{{#if tenant_names}}{{tenant_names}}{{else}}Not stated{{/if}}</td>
        <td class="label">Term / dates</td>
        <td>
          {{#if tenancy_start_date}}{{formatUKDate tenancy_start_date}}{{else}}Not stated{{/if}}
          {{#if tenancy_end_date}} to {{formatUKDate tenancy_end_date}}{{/if}}
        </td>
      </tr>
      <tr>
        <td class="label">Rent</td>
        <td>{{#if rent_amount_display}}{{rent_amount_display}}{{else}}Not stated{{/if}}</td>
        <td class="label">Deposit</td>
        <td>{{#if deposit_amount_display}}{{deposit_amount_display}}{{else}}Not stated{{/if}}</td>
      </tr>
    </table>
  </section>

  <h2 class="section-title">Parties</h2>
  <p class="opening">
    {{#if execution_as_deed}}
      This deed is made on {{formatUKDate document_date}} by the parties identified below in relation to the Property in England.
    {{else}}
      This agreement is made on {{formatUKDate document_date}} by the parties identified below in relation to the Property in England.
    {{/if}}
  </p>

  <table class="parties-table">
    {{#each parties}}
      <tr>
        <td class="role">{{label}}</td>
        <td>
          <div class="party-name">{{name}}</div>
          {{#if address}}<div class="party-detail">{{address}}</div>{{/if}}
          {{#if email}}<div class="party-detail">Email: {{email}}</div>{{/if}}
          {{#if phone}}<div class="party-detail">Telephone: {{phone}}</div>{{/if}}
        </td>
      </tr>
    {{/each}}
  </table>

  {{#if recitals.length}}
    <h2 class="section-title">Background</h2>
    <ol class="recitals">
      {{#each recitals}}
        <li>{{this}}</li>
      {{/each}}
    </ol>
  {{/if}}

  {{#if defined_terms.length}}
    <h2 class="section-title">Defined Terms</h2>
    <table class="detail-table">
      {{#each defined_terms}}
        <tr>
          <td class="label">{{term}}</td>
          <td>{{meaning}}</td>
        </tr>
      {{/each}}
    </table>
  {{/if}}

  <h2 class="section-title">Operative Provisions</h2>
  {{#each sections}}
    <section class="clause">
      <div class="clause-heading">{{add @index 1}}. {{heading}}</div>

      {{#if intro}}<p class="clause-intro">{{intro}}</p>{{/if}}

      {{#if rows}}
        <table class="detail-table">
          {{#each rows}}
            <tr>
              <td class="label">{{label}}</td>
              <td>{{value}}</td>
            </tr>
          {{/each}}
        </table>
      {{/if}}

      {{#if table}}
        <table class="detail-table">
          <tr>
            {{#each table.columns}}
              <td class="label">{{this}}</td>
            {{/each}}
          </tr>
          {{#each table.rows}}
            <tr>
              {{#each this}}
                <td>{{this}}</td>
              {{/each}}
            </tr>
          {{/each}}
        </table>
      {{/if}}

      {{#if paragraphs}}
        {{#each paragraphs}}
          <p>{{this}}</p>
        {{/each}}
      {{/if}}

      {{#if bullets}}
        <ul class="subpoints">
          {{#each bullets}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      {{/if}}
    </section>
  {{/each}}

  {{#if notes}}
    <div class="note-panel">
      <strong>Additional notes</strong>
      <p>{{notes}}</p>
    </div>
  {{/if}}

  {{#if deed_warning}}
    <div class="deed-warning">
      <strong>Execution reminder</strong><br>
      {{deed_warning}}
    </div>
  {{/if}}

  <section class="execution">
    <h2 class="section-title">Execution</h2>
    <p class="execution-copy">{{execution_statement}}</p>
    <div class="signatures">
      {{#each signature_parties}}
        <div class="signature-card">
          <div class="signature-role">{{label}}</div>
          <div class="signature-name">{{name}}</div>
          <div class="signature-line"></div>
          <div class="signature-meta">
            <span>Signature</span>
            <span>Date</span>
          </div>

          {{#if witnessRequired}}
            <div class="witness-block">
              <div class="witness-label">Witness</div>
              <div class="signature-line"></div>
              <div class="signature-meta">
                <span>Witness signature</span>
                <span>Date</span>
              </div>
              <div class="signature-line"></div>
              <div class="signature-meta">
                <span>Witness name</span>
                <span>Witness address</span>
              </div>
              {{#if witnessNote}}<div class="witness-note">{{witnessNote}}</div>{{/if}}
            </div>
          {{/if}}
        </div>
      {{/each}}
    </div>
  </section>

  <div class="footer">
    <span>Generated by Landlord Heaven</span>
    <span>{{document_reference}}</span>
  </div>
</body>
</html>
