<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>
    @page {
      size: A4;
      margin: 22mm 18mm;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      font-size: 10.75pt;
      line-height: 1.55;
      color: #18181b;
      background: #fff;
    }

    h1, h2, h3 {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: #111827;
      page-break-after: avoid;
    }

    .header {
      border: 1.5pt solid #1f2937;
      padding: 18pt 20pt;
      margin-bottom: 18pt;
    }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-size: 8pt;
      color: #4b5563;
      margin-bottom: 8pt;
      font-family: Arial, Helvetica, sans-serif;
    }

    h1 {
      font-size: 19pt;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .subtitle {
      margin-top: 7pt;
      color: #374151;
    }

    .intro {
      margin-top: 12pt;
      text-align: justify;
    }

    .meta-table,
    .detail-table {
      width: 100%;
      border-collapse: collapse;
      margin: 10pt 0 12pt;
      font-size: 10pt;
    }

    .meta-table td,
    .detail-table td {
      border: 0.75pt solid #9ca3af;
      padding: 8pt 9pt;
      vertical-align: top;
    }

    .meta-table .label,
    .detail-table .label {
      width: 28%;
      background: #f9fafb;
      font-family: Arial, Helvetica, sans-serif;
      font-weight: 700;
      color: #1f2937;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .section {
      margin-top: 16pt;
      page-break-inside: avoid;
    }

    .section h2 {
      font-size: 12pt;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      border-bottom: 1pt solid #111827;
      padding-bottom: 4pt;
      margin-bottom: 9pt;
    }

    p {
      margin: 0 0 8pt 0;
      text-align: justify;
    }

    ul {
      margin: 6pt 0 8pt 18pt;
      padding: 0;
    }

    li {
      margin-bottom: 6pt;
      text-align: justify;
    }

    .declaration {
      margin-top: 20pt;
      border: 0.75pt solid #9ca3af;
      padding: 14pt;
      background: #fcfcfd;
      page-break-inside: avoid;
    }

    .declaration h3 {
      font-size: 10.5pt;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 8pt;
    }

    .signature-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16pt;
      margin-top: 16pt;
    }

    .line {
      border-bottom: 1pt solid #1f2937;
      height: 30pt;
    }

    .footer {
      margin-top: 20pt;
      padding-top: 10pt;
      border-top: 0.75pt solid #9ca3af;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 8.5pt;
      color: #6b7280;
      display: flex;
      justify-content: space-between;
      gap: 10pt;
    }
  </style>
</head>
<body>
  <section class="header">
    <div class="eyebrow">England Residential Lettings</div>
    <h1>{{title}}</h1>
    <div class="subtitle">{{subtitle}}</div>
    {{#if intro}}<p class="intro">{{intro}}</p>{{/if}}

    <table class="meta-table">
      <tr>
        <td class="label">Applicant</td>
        <td>{{#if counterparty_name}}{{counterparty_name}}{{else}}{{tenant_primary_name}}{{/if}}</td>
        <td class="label">Reference</td>
        <td>{{document_reference}}</td>
      </tr>
      <tr>
        <td class="label">Property</td>
        <td>{{#if property_address}}{{property_address}}{{else}}Not stated{{/if}}</td>
        <td class="label">Application date</td>
        <td>{{formatUKDate generated_on}}</td>
      </tr>
      <tr>
        <td class="label">Expected rent</td>
        <td>{{#if rent_amount_display}}{{rent_amount_display}}{{else}}Not stated{{/if}}</td>
        <td class="label">Requested start</td>
        <td>{{#if tenancy_start_date}}{{formatUKDate tenancy_start_date}}{{else}}Not stated{{/if}}</td>
      </tr>
    </table>
  </section>

  {{#each sections}}
    <section class="section">
      <h2>{{heading}}</h2>

      {{#if rows}}
        <table class="detail-table">
          {{#each rows}}
            <tr>
              <td class="label">{{label}}</td>
              <td>{{value}}</td>
            </tr>
          {{/each}}
        </table>
      {{/if}}

      {{#if paragraphs}}
        {{#each paragraphs}}
          <p>{{this}}</p>
        {{/each}}
      {{/if}}

      {{#if bullets}}
        <ul>
          {{#each bullets}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      {{/if}}
    </section>
  {{/each}}

  {{#if notes}}
    <section class="section">
      <h2>Additional Notes</h2>
      <p>{{notes}}</p>
    </section>
  {{/if}}

  <section class="declaration">
    <h3>Applicant Declaration and Authority</h3>
    <p>
      I confirm that the information provided in this application is true, accurate, and complete to the best of my knowledge and belief. I understand that the Landlord or letting agent may rely on this information when deciding whether to offer a tenancy or request a guarantor.
    </p>
    <p>
      I authorise the Landlord, any instructed letting agent, and any third-party referencing provider to verify identity, address history, affordability, landlord references, employment, income, credit status, and right to rent information for the purposes of tenancy assessment, fraud prevention, and associated record keeping.
    </p>
    <p>
      I understand that deliberately false or misleading information may result in the application being declined or, if discovered later, may be relied on in connection with tenancy enforcement or recovery proceedings where relevant.
    </p>

    <div class="signature-grid">
      <div>
        <div class="line"></div>
        <div>Applicant signature</div>
      </div>
      <div>
        <div class="line"></div>
        <div>Date</div>
      </div>
    </div>
  </section>

  <div class="footer">
    <span>Generated by Landlord Heaven</span>
    <span>{{document_reference}}</span>
  </div>
</body>
</html>
