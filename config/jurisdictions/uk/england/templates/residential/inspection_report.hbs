<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>
    @page {
      size: A4;
      margin: 22mm 18mm;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      font-size: 10.75pt;
      line-height: 1.55;
      color: #18181b;
      background: #fff;
    }

    h1, h2, h3 {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: #111827;
      page-break-after: avoid;
    }

    .header {
      border: 1.5pt solid #1f2937;
      padding: 18pt 20pt;
      margin-bottom: 18pt;
    }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-size: 8pt;
      color: #4b5563;
      margin-bottom: 8pt;
      font-family: Arial, Helvetica, sans-serif;
    }

    h1 {
      font-size: 19pt;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .subtitle {
      margin-top: 7pt;
      color: #374151;
    }

    .intro {
      margin-top: 12pt;
      text-align: justify;
    }

    .summary-table,
    .detail-table {
      width: 100%;
      border-collapse: collapse;
      margin: 10pt 0 12pt;
      font-size: 10pt;
    }

    .summary-table td,
    .detail-table td {
      border: 0.75pt solid #9ca3af;
      padding: 8pt 9pt;
      vertical-align: top;
    }

    .summary-table .label,
    .detail-table .label {
      width: 28%;
      background: #f9fafb;
      font-family: Arial, Helvetica, sans-serif;
      font-weight: 700;
      color: #1f2937;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .section {
      margin-top: 16pt;
      page-break-inside: avoid;
    }

    .room-card,
    .appendix-card {
      margin-top: 16pt;
      border: 0.75pt solid #9ca3af;
      padding: 12pt 14pt;
      background: #fcfcfd;
      page-break-inside: avoid;
    }

    .room-card h3,
    .appendix-card h3 {
      font-size: 10.75pt;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 8pt;
    }

    .room-meta {
      margin-bottom: 10pt;
    }

    .section h2 {
      font-size: 12pt;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      border-bottom: 1pt solid #111827;
      padding-bottom: 4pt;
      margin-bottom: 9pt;
    }

    p {
      margin: 0 0 8pt 0;
      text-align: justify;
    }

    ul {
      margin: 6pt 0 8pt 18pt;
      padding: 0;
    }

    li {
      margin-bottom: 6pt;
      text-align: justify;
    }

    .certification {
      margin-top: 20pt;
      border: 0.75pt solid #9ca3af;
      padding: 14pt;
      background: #fcfcfd;
      page-break-inside: avoid;
    }

    .certification h3 {
      font-size: 10.5pt;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 8pt;
    }

    .signature-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16pt;
      margin-top: 16pt;
    }

    .line {
      border-bottom: 1pt solid #1f2937;
      height: 30pt;
    }

    .footer {
      margin-top: 20pt;
      padding-top: 10pt;
      border-top: 0.75pt solid #9ca3af;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 8.5pt;
      color: #6b7280;
      display: flex;
      justify-content: space-between;
      gap: 10pt;
    }
  </style>
</head>
<body>
  <section class="header">
    <div class="eyebrow">England Residential Lettings</div>
    <h1>{{title}}</h1>
    <div class="subtitle">{{subtitle}}</div>
    {{#if intro}}<p class="intro">{{intro}}</p>{{/if}}

    <table class="summary-table">
      <tr>
        <td class="label">Property</td>
        <td>{{#if property_address}}{{property_address}}{{else}}Not stated{{/if}}</td>
        <td class="label">Inspection date</td>
        <td>{{#if inspection_date}}{{formatUKDate inspection_date}}{{else}}Not stated{{/if}}</td>
      </tr>
      <tr>
        <td class="label">Inspector / landlord</td>
        <td>{{#if inspector_name}}{{inspector_name}}{{else}}{{#if landlord_name}}{{landlord_name}}{{else}}Not stated{{/if}}{{/if}}</td>
        <td class="label">Reference</td>
        <td>{{document_reference}}</td>
      </tr>
      <tr>
        <td class="label">Occupier(s)</td>
        <td>{{#if tenant_names}}{{tenant_names}}{{else}}Not stated{{/if}}</td>
        <td class="label">Tenancy dates</td>
        <td>
          {{#if tenancy_start_date}}{{formatUKDate tenancy_start_date}}{{else}}Not stated{{/if}}
          {{#if tenancy_end_date}} to {{formatUKDate tenancy_end_date}}{{/if}}
        </td>
      </tr>
    </table>
  </section>

  {{#if document_facts_rows.length}}
    <section class="section">
      <h2>Document Facts</h2>
      <table class="detail-table">
        {{#each document_facts_rows}}
          <tr>
            <td class="label">{{label}}</td>
            <td>{{value}}</td>
          </tr>
        {{/each}}
      </table>
    </section>
  {{/if}}

  {{#each sections}}
    <section class="section">
      <h2>{{heading}}</h2>

      {{#if rows}}
        <table class="detail-table">
          {{#each rows}}
            <tr>
              <td class="label">{{label}}</td>
              <td>{{value}}</td>
            </tr>
          {{/each}}
        </table>
      {{/if}}

      {{#if table}}
        <table class="detail-table">
          <tr>
            {{#each table.columns}}
              <td class="label">{{this}}</td>
            {{/each}}
          </tr>
          {{#each table.rows}}
            <tr>
              {{#each this}}
                <td>{{this}}</td>
              {{/each}}
            </tr>
          {{/each}}
        </table>
      {{/if}}

      {{#if paragraphs}}
        {{#each paragraphs}}
          <p>{{this}}</p>
        {{/each}}
      {{/if}}

      {{#if bullets}}
        <ul>
          {{#each bullets}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      {{/if}}
    </section>
  {{/each}}

  {{#if inspection_rooms.length}}
    <section class="section">
      <h2>Room-by-Room Record</h2>

      {{#each inspection_rooms}}
        <div class="room-card">
          <h3>{{name}}</h3>

          {{#if summary_rows.length}}
            <table class="detail-table room-meta">
              {{#each summary_rows}}
                <tr>
                  <td class="label">{{label}}</td>
                  <td>{{value}}</td>
                </tr>
              {{/each}}
            </table>
          {{/if}}

          {{#if item_rows.length}}
            <table class="detail-table">
              <tr>
                <td class="label">Item</td>
                <td class="label">Condition</td>
                <td class="label">Cleanliness</td>
                <td class="label">Notes</td>
              </tr>
              {{#each item_rows}}
                <tr>
                  <td>{{item}}</td>
                  <td>{{condition}}</td>
                  <td>{{cleanliness}}</td>
                  <td>{{notes}}</td>
                </tr>
              {{/each}}
            </table>
          {{/if}}

          {{#if observation_bullets.length}}
            <ul>
              {{#each observation_bullets}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
          {{/if}}

          {{#if photo_reference}}
            <p><strong>Photo reference:</strong> {{photo_reference}}</p>
          {{/if}}
        </div>
      {{/each}}
    </section>
  {{/if}}

  {{#if notes}}
    <section class="section">
      <h2>Additional Notes</h2>
      <p>{{notes}}</p>
    </section>
  {{/if}}

  {{#if evidence_appendix.length}}
    <section class="section">
      <h2>Evidence Appendix</h2>
      <div class="appendix-card">
        <table class="detail-table">
          <tr>
            <td class="label">Reference</td>
            <td class="label">File</td>
            <td class="label">Category</td>
            <td class="label">Uploaded</td>
          </tr>
          {{#each evidence_appendix}}
            <tr>
              <td>{{reference}}</td>
              <td>{{file_name}}</td>
              <td>{{category}}</td>
              <td>{{uploaded_at}}</td>
            </tr>
          {{/each}}
        </table>
      </div>
    </section>
  {{/if}}

  <section class="certification">
    <h3>Certification and Acknowledgement</h3>
    <p>
      This report is intended to create a dated evidential record of the visible condition of the Property, together with keys, meter readings, cleanliness, safety observations, defects, and follow-up items noted at the inspection. It should be retained with the tenancy agreement, inventory, photographs, certificates, and later comparison evidence.
    </p>
    <p>
      Any occupier attending the inspection should add written comments promptly if they disagree with any material point recorded here.
    </p>

    <div class="signature-grid">
      <div>
        <div class="line"></div>
        <div>Inspector / landlord signature</div>
      </div>
      <div>
        <div class="line"></div>
        <div>Occupier signature</div>
      </div>
    </div>
  </section>

  <div class="footer">
    <span>Generated by Landlord Heaven</span>
    <span>{{document_reference}}</span>
  </div>
</body>
</html>
