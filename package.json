{
  "name": "landlord-heavenv3",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev --webpack -H 0.0.0.0 -p 5000",
    "build": "npm run validate:yaml-config && next build --webpack",
    "postbuild": "node scripts/indexnow-submit.mjs",
    "start": "next start -H 0.0.0.0 -p 5000",
    "indexnow": "node scripts/indexnow-submit.mjs",
    "lint": "eslint",
    "test": "npx -p node@20 node .\\node_modules\\vitest\\vitest.mjs run",
    "validate:yaml-config": "npx -p node@20 -p tsx tsx scripts/validate-yaml-config.ts",
    "test:seo": "vitest tests/seo/single-h1-routes.test.tsx --run",
    "test:pdf": "RUN_PDF_TESTS=true vitest run",
    "test:notice-compliance": "vitest run notice-compliance",
    "law-monitor": "npx -p node@20 -p tsx tsx scripts/law-monitor-run.ts",
    "generate:england-tenancy-samples": "npx -p node@20 -p tsx tsx scripts/generate-england-tenancy-samples.ts",
    "generate:golden-packs": "set NODE_OPTIONS=--conditions=react-server && npx -p node@20 -p tsx tsx scripts/generate-england-golden-packs.ts",
    "audit:golden-pack-mapped-forms": "npx -p node@20 -p tsx tsx scripts/audit-golden-pack-mapped-forms.ts",
    "audit:notice-only": "npx -p node@20 -p tsx tsx scripts/audit-notice-only-pdfs.ts",
    "audit:notice-only:layout": "npx -p node@20 -p tsx tsx scripts/audit-notice-only-layout.ts",
    "audit:notice-only:visual": "npx -p node@20 -p tsx tsx scripts/render-notice-only-snapshots.ts && npx -p node@20 -p tsx tsx scripts/audit-notice-only-layout.ts",
    "audit:notice-only:all": "npx -p node@20 -p tsx tsx scripts/audit-notice-only-pdfs.ts && npx -p node@20 -p tsx tsx scripts/render-notice-only-snapshots.ts && npx -p node@20 -p tsx tsx scripts/audit-notice-only-layout.ts",
    "audit:official-forms-clean": "npx -p node@20 -p tsx tsx scripts/audit-official-forms-clean.ts",
    "audit:seo": "npx -p node@20 -p tsx tsx scripts/seo-audit.ts",
    "audit:sitemap": "npx -p node@20 -p tsx tsx scripts/sitemap-audit.ts",
    "prove:notice-only:e2e": "npx -p node@20 -p tsx tsx scripts/prove-notice-only-e2e.ts",
    "prove:notice-only:editable": "npx -p node@20 -p tsx tsx scripts/prove-notice-only-editable-html.ts",
    "validate:wizard-mappings": "npx -p node@20 -p tsx tsx scripts/validate-wizard-mappings.ts",
    "audit:legal-v2": "npx -p node@20 -p tsx tsx scripts/legal-validity-audit-v2.1.ts",
    "audit:cta-jurisdiction": "npx -p node@20 -p tsx tsx scripts/jurisdiction-cta-audit.ts",
    "audit:tenancy-variants": "npx -p node@20 -p tsx tsx scripts/audit-tenancy-variants.ts",
    "audit:tenancy-clauses": "npx -p node@20 -p tsx tsx scripts/audit-tenancy-clauses.ts",
    "audit:seo-metadata": "npx -p node@20 -p tsx tsx scripts/seo-metadata-audit.ts",
    "audit:seo-keywords": "npx -p node@20 -p tsx tsx scripts/seo-keyword-mapping-audit.ts",
    "audit:eviction-rules": "npx -p node@20 -p tsx tsx scripts/audit-eviction-rules.ts",
    "validation:status": "npx -p node@20 -p tsx tsx scripts/validation-status.ts",
    "validation:phase14-report": "npx -p node@20 -p tsx tsx scripts/phase14-impact-report.ts",
    "validation:lint-rules": "npx -p node@20 -p tsx tsx scripts/validation-lint-rules.ts",
    "validation:governance-check": "npx -p node@20 -p tsx tsx scripts/validation-governance-check.ts",
    "validation:dashboard": "npx -p node@20 -p tsx tsx scripts/validation-insights-dashboard.ts",
    "validation:rule-lookup": "npx -p node@20 -p tsx tsx scripts/validation-rule-lookup.ts",
    "validation:roi-report": "npx -p node@20 -p tsx tsx scripts/validation-roi-report.ts",
    "legal-change:ingest": "npx -p node@20 -p tsx tsx scripts/legal-change-ingest.ts",
    "ci": "npm run validate:yaml-config && npm run audit:official-forms-clean && npm run test && npm run validate:wizard-mappings && npm run audit:legal-v2 && npm run audit:tenancy-variants && npm run audit:tenancy-clauses && npm run audit:seo-metadata && npm run audit:eviction-rules && npm run validation:lint-rules && npm run validation:governance-check",
    "audit:sitemap-coverage": "node scripts/check-sitemap-coverage.mjs",
    "audit:main-text": "node scripts/assert-main-text.mjs",
    "audit:cannibalisation": "node scripts/cannibalisation-audit.mjs",
    "audit:funnel": "node scripts/run-with-server.mjs -- node scripts/funnel-audit.mjs",
    "audit:pw:install": "playwright install --with-deps",
    "audit:env:check": "node scripts/audit-env-check.mjs",
    "audit:positioning": "node --disable-warning=DEP0180 scripts/run-positioning-audit.mjs",
    "audit:positioning:strict": "node --disable-warning=DEP0180 scripts/run-positioning-audit.mjs --strict",
    "audit:positioning:warn-only": "node --disable-warning=DEP0180 scripts/run-positioning-audit.mjs --warn-only",
    "blog:recommend": "node scripts/blog-autofill-recommendations.mjs",
    "blog:recommend:strict": "node scripts/blog-autofill-recommendations.mjs --strict",
    "blog:images": "node scripts/blog-image-manifest.mjs",
    "blog:cta-smoke": "node --loader ts-node/esm scripts/blog-cta-smoke.mjs",
    "blog:images:distribution": "node scripts/blog-image-distribution.mjs",
    "audit:blog-surface": "node scripts/blog-surface-audit.mjs",
    "audit:s21": "npx -p node@20 -p tsx tsx scripts/audit-s21-content.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@sparticuz/chromium": "^143.0.4",
    "@stripe/stripe-js": "^8.5.2",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.84.0",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^1.6.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.554.0",
    "next": "^16.0.7",
    "openai": "^6.9.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^24.31.0",
    "puppeteer-core": "^24.34.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.66.1",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "resend": "^6.5.2",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "stripe": "^20.0.0",
    "tailwind-merge": "^3.4.0",
    "unpdf": "^1.4.0",
    "zod": "^3.25.76",
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.8.32",
    "canvas": "^3.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "jsdom": "^26.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
